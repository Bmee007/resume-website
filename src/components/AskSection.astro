---
// AskSection.astro — Interactive AI demo: "Ask Borina Keo to show you."
---

<section id="ask" class="ask-section">

  <!-- Full-width header -->
  <div class="ask-header">
    <span class="section-num" aria-hidden="true">02</span>
    <h2 class="ask-heading">
      Ask Borina Keo<br />
      <em>to show you.</em>
    </h2>
    <p class="ask-subhead">
      Type a question or pick a prompt — the dashboard answers in real time.
    </p>
  </div>

  <!-- 2-column split: chat left, bento right -->
  <div class="ask-split">

    <!-- LEFT: chat panel -->
    <div class="ask-left">

      <!-- Prompt chips -->
      <div class="ask-chips" id="ask-chips">
        <button class="ask-chip" data-prompt="How did you use Azure OpenAI in production?">
          How did you use Azure OpenAI?
        </button>
        <button class="ask-chip" data-prompt="What is your Microsoft Dynamics 365 expertise?">
          What's your D365 expertise?
        </button>
        <button class="ask-chip" data-prompt="Tell me about the $2.4M cost reduction you drove">
          Tell me about the $2.4M impact
        </button>
        <button class="ask-chip" data-prompt="What results have you driven for Fortune 500 companies?">
          What results have you driven?
        </button>
      </div>

      <!-- Input row -->
      <div class="ask-input-row">
        <input
          id="ask-input"
          type="text"
          class="ask-input-field"
          placeholder="Ask me anything about my work…"
          maxlength="500"
          autocomplete="off"
          aria-label="Ask a question about Borina Keo's work"
        />
        <button id="ask-send" class="ask-send-btn" disabled aria-label="Send question">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="22" y1="2" x2="11" y2="13"></line>
            <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
          </svg>
        </button>
      </div>

      <div id="ask-status" class="ask-status" aria-live="polite" aria-atomic="true"></div>
    </div>

    <!-- RIGHT: bento dashboard -->
    <div id="ask-bento" class="ask-bento">

      <!-- Big metric card — default hero (spans 2 rows) -->
      <div id="card-metric-big" class="bento-card bento-hero" data-card="metric">
        <div class="card-tag">Documented Impact</div>
        <div class="mini-bars" aria-hidden="true">
          <div class="bar" style="height:30%"></div>
          <div class="bar" style="height:45%"></div>
          <div class="bar" style="height:55%"></div>
          <div class="bar" style="height:40%"></div>
          <div class="bar" style="height:65%"></div>
          <div class="bar" style="height:72%"></div>
          <div class="bar bar--hi" style="height:88%"></div>
          <div class="bar bar--hi" style="height:95%"></div>
          <div class="bar bar--hi" style="height:100%"></div>
        </div>
        <div id="metric-value" class="big-num">$2.4M</div>
        <div id="metric-label" class="big-label">Operational cost reduction<br />via AI automation</div>
        <div id="metric-sub" class="big-sub">Across D365 + Manhattan DFIO integrations<br />over 3 enterprise deployments</div>
      </div>

      <!-- AI Alert feed -->
      <div id="card-alert" class="bento-card" data-card="alert">
        <div class="alert-header">
          <div class="alert-title">D365 AI Monitor</div>
          <div class="alert-badge">
            <span class="pulse-dot" aria-hidden="true"></span>Live
          </div>
        </div>
        <div id="alert-list">
          <div class="alert-item">
            <div class="alert-icon" aria-hidden="true">⚡</div>
            <div>
              <div class="alert-text">Demand spike detected: SKU-7842 +340%</div>
              <div class="alert-meta">Azure OpenAI · just now · auto-routed to procurement</div>
            </div>
          </div>
          <div class="alert-item alert-item--green">
            <div class="alert-icon" aria-hidden="true">✓</div>
            <div>
              <div class="alert-text">BOL-93241 classified &amp; matched to PO</div>
              <div class="alert-meta">GPT-4o · 8s ago · 0.24s processing time</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Years experience -->
      <div id="card-yrs" class="bento-card" data-card="experience">
        <div class="card-tag">Experience</div>
        <div class="yr-num">15+</div>
        <div class="yr-label">Years Enterprise Leadership</div>
        <div class="yr-sub">Microsoft Dynamics 365 · Manhattan WMS<br />Fortune 500 distribution networks</div>
      </div>

      <!-- AI response card -->
      <div id="card-ai" class="bento-card" data-card="ai" aria-live="polite">
        <div class="card-tag">Copilot Studio · Live</div>
        <div class="ai-prompt" id="ai-prompt-text">"What can Borina Keo do for my business?"</div>
        <div class="ai-response" id="ai-response-text">
          Ask a question to see the AI respond in real time.
        </div>
        <div class="ai-dots" id="ai-dots" aria-hidden="true">
          <span class="dot-anim"></span>
          <span class="dot-anim"></span>
          <span class="dot-anim"></span>
        </div>
      </div>

      <!-- Skills — always spans full row -->
      <div id="card-skills" class="bento-card bento-full-row" data-card="skills">
        <div class="card-tag">Core Competencies</div>
        <div id="skill-list" class="skill-list">
          <div class="skill-row">
            <div class="skill-top">
              <span class="skill-name">Microsoft Dynamics 365</span>
              <span class="skill-pct">98%</span>
            </div>
            <div class="skill-bar-bg">
              <div class="skill-bar-fill skill-bar-fill--amber" style="width:98%"></div>
            </div>
          </div>
          <div class="skill-row">
            <div class="skill-top">
              <span class="skill-name">Azure OpenAI / AI Builder</span>
              <span class="skill-pct skill-pct--blue">91%</span>
            </div>
            <div class="skill-bar-bg">
              <div class="skill-bar-fill skill-bar-fill--blue" style="width:91%"></div>
            </div>
          </div>
          <div class="skill-row">
            <div class="skill-top">
              <span class="skill-name">Manhattan DFIO / WMS</span>
              <span class="skill-pct skill-pct--green">95%</span>
            </div>
            <div class="skill-bar-bg">
              <div class="skill-bar-fill skill-bar-fill--green" style="width:95%"></div>
            </div>
          </div>
        </div>
      </div>

    </div><!-- /#ask-bento -->
  </div><!-- /.ask-split -->
</section>

<style>
  /* ── Extra color tokens (not in global.css) ─────────────── */
  .ask-section {
    --green: oklch(0.72 0.18 145);
    --blue:  oklch(0.65 0.17 240);
  }

  /* ── Section wrapper ─────────────────────────────────────── */
  .ask-section {
    padding: clamp(5rem, 12vw, 9rem) clamp(1.5rem, 5vw, 4rem);
    max-width: 80rem;
    margin: 0 auto;
  }

  /* ── Full-width header ───────────────────────────────────── */
  .ask-header {
    border-bottom: 1px solid var(--border);
    padding-bottom: clamp(2rem, 4vw, 3rem);
    margin-bottom: clamp(2.5rem, 5vw, 4rem);
    display: grid;
    grid-template-columns: auto 1fr;
    grid-template-rows: auto auto;
    column-gap: clamp(1.5rem, 3vw, 2.5rem);
    align-items: start;
  }

  .section-num {
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--amber);
    margin-top: 0.85rem;
    grid-row: 1 / 3;
  }

  .ask-heading {
    font-family: "DM Serif Display", Georgia, serif;
    font-style: normal;
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--cream);
    grid-column: 2;
    grid-row: 1;
  }

  .ask-heading em {
    font-style: italic;
    color: var(--amber);
  }

  .ask-subhead {
    font-size: clamp(0.9rem, 1.5vw, 1.0625rem);
    color: var(--fg-muted);
    line-height: 1.65;
    grid-column: 2;
    grid-row: 2;
    margin-top: 0.75rem;
    max-width: 44rem;
  }

  /* ── 2-column split ──────────────────────────────────────── */
  .ask-split {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: clamp(2rem, 4vw, 4rem);
    align-items: start;
  }

  /* ── LEFT: chat panel ────────────────────────────────────── */
  .ask-left {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    position: sticky;
    top: 5.5rem;
  }

  .ask-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .ask-chip {
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--amber);
    background: transparent;
    border: 1px solid color-mix(in oklch, var(--amber) 40%, transparent);
    padding: 0.4rem 0.75rem;
    cursor: pointer;
    transition: background 0.2s ease, color 0.2s ease;
    text-align: left;
    line-height: 1.35;
  }

  .ask-chip:hover {
    background: color-mix(in oklch, var(--amber) 12%, transparent);
    border-color: var(--amber);
  }

  .ask-input-row {
    display: flex;
    gap: 0.5rem;
  }

  .ask-input-field {
    flex: 1;
    background: var(--surface-raised, oklch(0.16 0.009 58));
    border: 1px solid var(--border-strong);
    color: var(--cream);
    font-size: 0.9rem;
    font-family: inherit;
    padding: 0.625rem 0.875rem;
    outline: none;
    transition: border-color 0.2s ease;
    min-width: 0;
  }

  .ask-input-field::placeholder {
    color: var(--fg-subtle);
  }

  .ask-input-field:focus {
    border-color: var(--amber);
  }

  .ask-send-btn {
    background: var(--amber);
    color: var(--bg, oklch(0.08 0.008 60));
    border: none;
    padding: 0 1rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: opacity 0.2s ease;
  }

  .ask-send-btn:disabled {
    opacity: 0.35;
    cursor: not-allowed;
  }

  .ask-send-btn:not(:disabled):hover {
    opacity: 0.85;
  }

  .ask-status {
    font-size: 0.75rem;
    color: var(--fg-subtle);
    min-height: 1.2em;
    line-height: 1.4;
  }

  /* ── RIGHT: bento grid ───────────────────────────────────── */
  .ask-bento {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: 1fr 1fr 1fr;
    gap: 0.75rem;
    height: 520px;
  }

  .bento-card {
    background: var(--surface, oklch(0.12 0.008 60));
    border: 1px solid var(--border);
    padding: 1.125rem 1.25rem;
    position: relative;
    overflow: hidden;
  }

  .bento-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--amber), transparent);
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .bento-card:hover::before {
    opacity: 1;
  }

  /* Hero slot: spans 2 rows (default: card-metric-big) */
  .bento-hero {
    grid-row: span 2;
  }

  /* Full-width bottom row (always: card-skills) */
  .bento-full-row {
    grid-column: span 2;
  }

  /* ── Card: tag ───────────────────────────────────────────── */
  .card-tag {
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--fg-subtle);
    margin-bottom: 0.5rem;
  }

  /* ── Card: metric ────────────────────────────────────────── */
  #card-metric-big {
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
  }

  .mini-bars {
    display: flex;
    align-items: flex-end;
    gap: 3px;
    height: 48px;
    margin-top: auto;
    margin-bottom: 1rem;
  }

  .bar {
    flex: 1;
    background: color-mix(in oklch, var(--amber) 20%, transparent);
    border-radius: 1px 1px 0 0;
    min-height: 4px;
  }

  .bar--hi {
    background: var(--amber);
  }

  .big-num {
    font-family: "DM Serif Display", Georgia, serif;
    font-size: 4.5rem;
    line-height: 1;
    color: var(--amber);
    margin-bottom: 0.5rem;
  }

  .big-label {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--cream);
    line-height: 1.35;
    margin-bottom: 0.5rem;
  }

  .big-sub {
    font-size: 0.75rem;
    color: var(--fg-muted);
    line-height: 1.5;
  }

  /* ── Card: alert ─────────────────────────────────────────── */
  #card-alert {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .alert-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .alert-title {
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--fg-muted);
  }

  .alert-badge {
    font-size: 0.5625rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--green);
    border: 1px solid color-mix(in oklch, var(--green) 40%, transparent);
    padding: 0.15rem 0.4rem;
    display: flex;
    align-items: center;
    gap: 0.3rem;
  }

  .pulse-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--green);
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.3; }
  }

  .alert-item {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    padding: 0.5rem 0.625rem;
    background: var(--surface-raised, oklch(0.16 0.009 58));
    border-left: 2px solid var(--amber);
  }

  .alert-item--green {
    border-left-color: var(--green);
    opacity: 0.75;
  }

  .alert-icon {
    font-size: 0.75rem;
    flex-shrink: 0;
    margin-top: 0.05rem;
  }

  .alert-text {
    font-size: 0.75rem;
    color: var(--fg);
    line-height: 1.45;
  }

  .alert-meta {
    font-size: 0.625rem;
    color: var(--fg-subtle);
    margin-top: 0.2rem;
  }

  /* ── Card: years ─────────────────────────────────────────── */
  #card-yrs {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.25rem;
  }

  .yr-num {
    font-family: "DM Serif Display", Georgia, serif;
    font-size: 3.5rem;
    line-height: 1;
    color: var(--amber);
  }

  .yr-label {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--cream);
  }

  .yr-sub {
    font-size: 0.75rem;
    color: var(--fg-muted);
    margin-top: 0.25rem;
    line-height: 1.45;
  }

  /* ── Card: AI response ───────────────────────────────────── */
  #card-ai {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    overflow: hidden;
  }

  .ai-prompt {
    font-size: 0.75rem;
    color: var(--fg-subtle);
    padding: 0.4rem 0.625rem;
    background: oklch(0.10 0.007 58);
    border: 1px solid var(--border);
    line-height: 1.4;
  }

  .ai-response {
    font-size: 0.8125rem;
    color: var(--fg);
    padding: 0.5rem 0.625rem;
    background: var(--surface-raised, oklch(0.16 0.009 58));
    border-left: 2px solid var(--amber);
    line-height: 1.55;
    flex: 1;
    overflow: hidden;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 5;
  }

  .ai-dots {
    display: none;
    gap: 3px;
    align-items: center;
  }

  .dot-anim {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--amber);
    opacity: 0.5;
    animation: dotPulse 1.4s ease-in-out infinite;
  }

  .dot-anim:nth-child(2) { animation-delay: 0.2s; }
  .dot-anim:nth-child(3) { animation-delay: 0.4s; }

  @keyframes dotPulse {
    0%, 80%, 100% { transform: scale(0.7); opacity: 0.3; }
    40%           { transform: scale(1);   opacity: 1; }
  }

  /* ── Card: skills ────────────────────────────────────────── */
  #card-skills {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .skill-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
    justify-content: space-around;
  }

  .skill-row {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .skill-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .skill-name {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--fg-muted);
  }

  .skill-pct {
    font-size: 0.6875rem;
    font-weight: 600;
    color: var(--amber);
  }

  .skill-pct--blue  { color: var(--blue); }
  .skill-pct--green { color: var(--green); }

  .skill-bar-bg {
    height: 3px;
    background: var(--border);
    border-radius: 2px;
    overflow: hidden;
  }

  .skill-bar-fill {
    height: 100%;
    border-radius: 2px;
    transition: width 0.6s ease;
  }

  .skill-bar-fill--amber { background: var(--amber); }
  .skill-bar-fill--blue  { background: var(--blue); }
  .skill-bar-fill--green { background: var(--green); }

  /* ── Mobile ──────────────────────────────────────────────── */
  @media (max-width: 767px) {
    .ask-split {
      grid-template-columns: 1fr;
    }

    .ask-left {
      position: static;
    }

    .ask-bento {
      height: auto;
      grid-template-rows: auto;
    }

    .bento-hero {
      grid-row: span 1;
    }

    .big-num {
      font-size: 3.5rem;
    }
  }
</style>
