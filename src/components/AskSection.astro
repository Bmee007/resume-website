---
// AskSection.astro — Interactive AI demo: "Ask Borina Keo to show you."
---

<section id="ask" class="ask-section">

  <!-- Full-width header -->
  <div class="ask-header">
    <span class="section-num" aria-hidden="true">02</span>
    <h2 class="ask-heading">
      Ask Borina Keo<br />
      <em>to show you.</em>
    </h2>
    <p class="ask-subhead">
      Type a question or pick a prompt — the dashboard answers in real time.
    </p>
  </div>

  <!-- 2-column split: chat left, bento right -->
  <div class="ask-split">

    <!-- LEFT: chat panel -->
    <div class="ask-left">

      <!-- Prompt chips -->
      <div class="ask-chips" id="ask-chips">
        <button class="ask-chip" data-prompt="How did you use Azure OpenAI in production?">
          How did you use Azure OpenAI?
        </button>
        <button class="ask-chip" data-prompt="What is your Microsoft Dynamics 365 expertise?">
          What's your D365 expertise?
        </button>
        <button class="ask-chip" data-prompt="Tell me about the $2.4M cost reduction you drove">
          Tell me about the $2.4M impact
        </button>
        <button class="ask-chip" data-prompt="What results have you driven for Fortune 500 companies?">
          What results have you driven?
        </button>
      </div>

      <!-- Input row -->
      <div class="ask-input-row">
        <input
          id="ask-input"
          type="text"
          class="ask-input-field"
          placeholder="Ask me anything about my work…"
          maxlength="500"
          autocomplete="off"
          aria-label="Ask a question about Borina Keo's work"
        />
        <button id="ask-send" class="ask-send-btn" disabled aria-label="Send question">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="22" y1="2" x2="11" y2="13"></line>
            <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
          </svg>
        </button>
      </div>

      <div id="ask-status" class="ask-status" aria-live="polite" aria-atomic="true"></div>
    </div>

    <!-- RIGHT: 3 panels -->
    <div class="ask-panels">

      <!-- Panel 1: streamed text answer -->
      <div id="panel-answer" class="ask-panel panel-answer" aria-live="polite">
        <span class="panel-tag">Answer</span>
        <div id="answer-text" class="answer-text">Ask a question to see the response here.</div>
        <div id="answer-error" class="panel-error" style="display:none">
          <span class="panel-error-icon" aria-hidden="true">⚠</span>
          <span class="panel-error-msg">Unable to reach the AI. Check your connection and try again, or reload the page.</span>
        </div>
        <div id="answer-dots" class="ai-dots" aria-hidden="true">
          <span class="dot-anim"></span>
          <span class="dot-anim"></span>
          <span class="dot-anim"></span>
        </div>
      </div>

      <!-- Row 2: image + chart -->
      <div class="ask-panels-row2">
        <div id="panel-image" class="ask-panel panel-image">
          <span class="panel-tag">Visual</span>
          <div class="image-wrap">
            <div id="image-skeleton" class="panel-skeleton" style="display:none"></div>
            <div id="generated-visual" class="generated-visual"></div>
          </div>
        </div>
        <div id="panel-chart" class="ask-panel panel-chart">
          <span class="panel-tag">Metrics</span>
          <p id="chart-title" class="chart-title"></p>
          <div class="chart-wrap">
            <div id="chart-skeleton" class="panel-skeleton" style="display:none"></div>
            <div id="chart-error" class="panel-error" style="display:none" aria-live="polite">
              <span class="panel-error-icon" aria-hidden="true">⚠</span>
              <span class="panel-error-msg">Chart data unavailable for this question. Try asking about a specific metric or outcome.</span>
            </div>
            <canvas id="answer-chart"></canvas>
          </div>
        </div>
      </div>

    </div>

  </div><!-- /.ask-split -->
</section>

<style>
  /* ── Extra color tokens (not in global.css) ─────────────── */
  .ask-section {
    --green: oklch(0.72 0.18 145);
    --blue:  oklch(0.65 0.17 240);
  }

  /* ── Section wrapper ─────────────────────────────────────── */
  .ask-section {
    padding: clamp(5rem, 10vw, 8rem) clamp(1.5rem, 5vw, 4rem) clamp(6rem, 12vw, 10rem);
    max-width: 100rem;
    margin: 0 auto;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  /* ── Full-width header ───────────────────────────────────── */
  .ask-header {
    border-bottom: 1px solid var(--border);
    padding-bottom: clamp(2rem, 4vw, 3rem);
    margin-bottom: clamp(2.5rem, 5vw, 4rem);
    display: grid;
    grid-template-columns: auto 1fr;
    grid-template-rows: auto auto;
    column-gap: clamp(1.5rem, 3vw, 2.5rem);
    align-items: start;
  }

  .section-num {
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--amber);
    margin-top: 0.85rem;
    grid-row: 1 / 3;
  }

  .ask-heading {
    font-family: "DM Serif Display", Georgia, serif;
    font-style: normal;
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--cream);
    grid-column: 2;
    grid-row: 1;
  }

  .ask-heading em {
    font-style: italic;
    color: var(--amber);
  }

  .ask-subhead {
    font-size: clamp(0.9rem, 1.5vw, 1.0625rem);
    color: var(--fg-muted);
    line-height: 1.65;
    grid-column: 2;
    grid-row: 2;
    margin-top: 0.75rem;
    max-width: 44rem;
  }

  /* ── 2-column split ──────────────────────────────────────── */
  .ask-split {
    display: grid;
    grid-template-columns: minmax(260px, 300px) 1fr;
    gap: clamp(2rem, 4vw, 4rem);
    align-items: start;
  }

  /* ── LEFT: chat panel ────────────────────────────────────── */
  .ask-left {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    position: sticky;
    top: 5.5rem;
  }

  .ask-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .ask-chip {
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--amber);
    background: transparent;
    border: 1px solid color-mix(in oklch, var(--amber) 40%, transparent);
    padding: 0.4rem 0.75rem;
    cursor: pointer;
    transition: background 0.2s ease, color 0.2s ease;
    text-align: left;
    line-height: 1.35;
  }

  .ask-chip:hover {
    background: color-mix(in oklch, var(--amber) 12%, transparent);
    border-color: var(--amber);
  }

  .ask-input-row {
    display: flex;
    gap: 0.5rem;
  }

  .ask-input-field {
    flex: 1;
    background: var(--surface-raised, oklch(0.16 0.009 58));
    border: 1px solid var(--border-strong);
    color: var(--cream);
    font-size: 0.9rem;
    font-family: inherit;
    padding: 0.625rem 0.875rem;
    outline: none;
    transition: border-color 0.2s ease;
    min-width: 0;
  }

  .ask-input-field::placeholder {
    color: var(--fg-subtle);
  }

  .ask-input-field:focus {
    border-color: var(--amber);
  }

  .ask-send-btn {
    background: var(--amber);
    color: var(--bg, oklch(0.08 0.008 60));
    border: none;
    padding: 0 1rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: opacity 0.2s ease;
  }

  .ask-send-btn:disabled {
    opacity: 0.35;
    cursor: not-allowed;
  }

  .ask-send-btn:not(:disabled):hover {
    opacity: 0.85;
  }

  .ask-status {
    font-size: 0.75rem;
    color: var(--fg-subtle);
    min-height: 1.2em;
    line-height: 1.4;
  }

  /* ── RIGHT: 3 panels ────────────────────────────────────── */
  .ask-panels {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .ask-panels-row2 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .ask-panel {
    background: var(--surface, oklch(0.12 0.008 60));
    border: 1px solid var(--border);
    padding: 1.125rem 1.25rem;
    position: relative;
    overflow: hidden;
  }

  .ask-panel::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--amber), transparent);
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .ask-panel:hover::before { opacity: 1; }

  .panel-tag {
    display: block;
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--fg-subtle);
    margin-bottom: 0.625rem;
  }

  /* ── Panel 1: answer ─────────────────────────────────────── */
  .panel-answer {
    min-height: clamp(160px, 16vw, 240px);
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .answer-text {
    font-size: clamp(0.9375rem, 1.2vw, 1.0625rem);
    color: var(--fg);
    line-height: 1.7;
    flex: 1;
  }

  :global(.hl) {
    color: var(--amber);
    font-weight: 600;
  }

  .ai-dots {
    display: none;
    gap: 3px;
    align-items: center;
  }

  .dot-anim {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--amber);
    opacity: 0.5;
    animation: dotPulse 1.4s ease-in-out infinite;
  }

  .dot-anim:nth-child(2) { animation-delay: 0.2s; }
  .dot-anim:nth-child(3) { animation-delay: 0.4s; }

  @keyframes dotPulse {
    0%, 80%, 100% { transform: scale(0.7); opacity: 0.3; }
    40%           { transform: scale(1);   opacity: 1; }
  }

  /* ── Panels 2 & 3: image + chart ─────────────────────────── */
  .panel-image,
  .panel-chart {
    height: clamp(360px, 38vw, 520px);
    display: flex;
    flex-direction: column;
  }

  .image-wrap {
    position: relative;
    flex: 1;
    overflow: hidden;
  }

  .generated-visual {
    display: none;
    flex-direction: column;
    gap: 0.4rem;
    padding: 0.5rem 0.75rem;
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  /* ── Stat card inner elements (dynamically injected via innerHTML — must be :global) */
  :global(.vis-question) {
    font-size: 0.6rem;
    color: var(--fg-subtle);
    font-style: italic;
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  :global(.vis-hero) {
    text-align: center;
    padding: 0.25rem 0 0.35rem;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }

  :global(.vis-hero-value) {
    font-size: 1.55rem;
    font-weight: 700;
    color: var(--amber);
    line-height: 1;
    letter-spacing: -0.02em;
  }

  :global(.vis-hero-label) {
    font-size: 0.58rem;
    color: var(--fg-muted);
    margin-top: 0.2rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  :global(.vis-bars) {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    flex: 1;
    overflow: hidden;
    justify-content: center;
  }

  :global(.vis-bar-row) {
    display: grid;
    grid-template-columns: 3.5rem 1fr 2.8rem;
    gap: 0.35rem;
    align-items: center;
  }

  :global(.vis-bar-label) {
    font-size: 0.56rem;
    color: var(--fg-muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  :global(.vis-bar-track) {
    height: 5px;
    background: rgba(255,255,255,0.06);
    border-radius: 3px;
    overflow: hidden;
  }

  :global(.vis-bar-fill) {
    height: 100%;
    background: var(--amber, #d49820);
    border-radius: 3px;
  }

  :global(.vis-bar-value) {
    font-size: 0.56rem;
    font-weight: 600;
    color: var(--fg);
    white-space: nowrap;
    text-align: right;
  }

  .chart-title {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--fg-muted);
    margin: 0 0 0.5rem;
    line-height: 1.3;
  }

  .chart-wrap {
    position: relative;
    flex: 1;
    min-height: 0;
    overflow: hidden;
  }

  #answer-chart {
    position: absolute;
    inset: 0;
    width: 100% !important;
    height: 100% !important;
    display: none;
  }

  /* ── Panel error states ──────────────────────────────────── */
  .panel-error {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 1rem;
    text-align: center;
    background: var(--surface, oklch(0.12 0.008 60));
    border: 1px dashed color-mix(in oklch, var(--amber) 30%, transparent);
  }

  /* For panel-answer the error sits in flow, not absolute */
  #panel-answer .panel-error {
    position: static;
    border: none;
    padding: 0.25rem 0;
    align-items: flex-start;
    text-align: left;
    background: transparent;
    flex-direction: row;
    gap: 0.5rem;
  }

  .panel-error-icon {
    font-size: 1rem;
    opacity: 0.5;
    flex-shrink: 0;
    line-height: 1.5;
  }

  .panel-error-msg {
    font-size: 0.75rem;
    color: var(--fg-muted);
    line-height: 1.55;
  }

  /* ── Skeleton generation status ─────────────────────────── */
  .skeleton-status {
    position: absolute;
    bottom: 1rem;
    left: 0;
    right: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    z-index: 1;
  }

  .skeleton-label {
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--fg-subtle);
  }

  .skeleton-sep {
    color: var(--border-strong);
    font-size: 0.75rem;
  }

  .skeleton-timer {
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: var(--amber);
    font-variant-numeric: tabular-nums;
    min-width: 2ch;
  }

  /* ── Skeleton shimmer ────────────────────────────────────── */
  .panel-skeleton {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      90deg,
      var(--surface, oklch(0.12 0.008 60)) 0%,
      oklch(0.17 0.012 60) 50%,
      var(--surface, oklch(0.12 0.008 60)) 100%
    );
    background-size: 200% 100%;
    animation: shimmer 1.8s ease-in-out infinite;
  }

  .panel-skeleton.skeleton-error {
    animation: none;
    background: var(--surface, oklch(0.12 0.008 60));
    display: flex !important;
    align-items: center;
    justify-content: center;
  }

  .panel-skeleton.skeleton-error::after {
    content: '⚠';
    font-size: 1.5rem;
    opacity: 0.3;
  }

  @keyframes shimmer {
    0%   { background-position: -200% 0; }
    100% { background-position:  200% 0; }
  }

  /* ── Mobile ──────────────────────────────────────────────── */
  @media (max-width: 767px) {
    .ask-section {
      min-height: auto;
    }

    .ask-split {
      grid-template-columns: 1fr;
    }

    .ask-left {
      position: static;
    }

    .ask-panels-row2 {
      grid-template-columns: 1fr;
    }

    .panel-image,
    .panel-chart {
      height: clamp(260px, 70vw, 360px);
    }
  }
</style>
