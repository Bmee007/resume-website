---
// AskSection.astro — Interactive AI demo: "Ask Borina Keo to show you."
---

<section id="ask" class="ask-section">

  <!-- Full-width header -->
  <div class="ask-header">
    <span class="section-num" aria-hidden="true">02</span>
    <h2 class="ask-heading">
      Ask Illumi<br />
      <em>(agent)</em>
    </h2>
    <p class="ask-subhead">
      Type a question or pick a prompt — the AI answers using Borina's verified data.
    </p>
  </div>

  <!-- Controls: chips + full-width input bar -->
  <div class="ask-controls">

    <!-- Prompt chips -->
    <div class="ask-chips" id="ask-chips">
      <button class="ask-chip" data-prompt="How do you build AI agents with custom harnesses and workflows?">
        How do you build AI agents?
      </button>
      <button class="ask-chip" data-prompt="What supply chain and retail AI systems have you deployed?">
        Supply chain AI deployments
      </button>
      <button class="ask-chip" data-prompt="Tell me about your LLM memory research and agent security work">
        LLM memory &amp; agent security
      </button>
      <button class="ask-chip" data-prompt="What results have you driven for companies like Kohl and Frisch?">
        Enterprise impact &amp; results
      </button>
    </div>

    <!-- Input bar -->
    <div class="ask-input-row">
      <input
        id="ask-input"
        type="text"
        class="ask-input-field"
        placeholder="Ask me anything about my work…"
        maxlength="500"
        autocomplete="off"
        aria-label="Ask Illumi a question about Borina Keo's work"
      />
      <button id="ask-send" class="ask-send-btn" disabled aria-label="Send question">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="22" y1="2" x2="11" y2="13"></line>
          <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
        </svg>
      </button>
    </div>

    <div id="ask-status" class="ask-status" aria-live="polite" aria-atomic="true"></div>
  </div>

  <!-- Full-width 3-panel grid: Answer · Visual · Metrics -->
  <div class="ask-panels">

    <!-- Panel 1: streamed text answer -->
    <div id="panel-answer" class="ask-panel panel-answer" aria-live="polite">
      <span class="panel-tag">Answer</span>
      <div id="answer-text" class="answer-text">Ask a question to see the response here.</div>
      <div id="answer-error" class="panel-error" style="display:none">
        <span class="panel-error-icon" aria-hidden="true">⚠</span>
        <span class="panel-error-msg">Unable to reach the AI. Check your connection and try again, or reload the page.</span>
      </div>
      <div id="answer-dots" class="ai-dots" aria-hidden="true">
        <span class="dot-anim"></span>
        <span class="dot-anim"></span>
        <span class="dot-anim"></span>
      </div>
    </div>

    <!-- Panel 2: visual -->
    <div id="panel-image" class="ask-panel panel-image">
      <span class="panel-tag">Visual</span>
      <div class="image-wrap">
        <div id="image-skeleton" class="panel-skeleton" style="display:none"></div>
        <div id="generated-visual" class="generated-visual"></div>
      </div>
    </div>

    <!-- Panel 3: chart -->
    <div id="panel-chart" class="ask-panel panel-chart">
      <span class="panel-tag">Metrics</span>
      <p id="chart-title" class="chart-title"></p>
      <div class="chart-wrap">
        <div id="chart-skeleton" class="panel-skeleton" style="display:none"></div>
        <div id="chart-error" class="panel-error" style="display:none" aria-live="polite">
          <span class="panel-error-icon" aria-hidden="true">⚠</span>
          <span class="panel-error-msg">Chart data unavailable for this question. Try asking about a specific metric or outcome.</span>
        </div>
        <canvas id="answer-chart"></canvas>
      </div>
    </div>

  </div>

</section>

<style>
  /* ── Extra color tokens (not in global.css) ─────────────── */
  .ask-section {
    --green: oklch(0.72 0.18 145);
    --blue:  oklch(0.65 0.17 240);
  }

  /* ── Section wrapper ─────────────────────────────────────── */
  .ask-section {
    padding: clamp(5rem, 10vw, 8rem) clamp(1.5rem, 5vw, 4rem) clamp(6rem, 12vw, 10rem);
    max-width: 100rem;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  /* ── Full-width header ───────────────────────────────────── */
  .ask-header {
    border-bottom: 1px solid var(--border);
    padding-bottom: clamp(2rem, 4vw, 3rem);
    margin-bottom: clamp(2rem, 4vw, 3rem);
    display: grid;
    grid-template-columns: auto 1fr;
    grid-template-rows: auto auto;
    column-gap: clamp(1.5rem, 3vw, 2.5rem);
    align-items: start;
  }

  .section-num {
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--amber);
    margin-top: 0.85rem;
    grid-row: 1 / 3;
  }

  .ask-heading {
    font-family: "DM Serif Display", Georgia, serif;
    font-style: normal;
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--cream);
    grid-column: 2;
    grid-row: 1;
  }

  .ask-heading em {
    font-style: italic;
    color: var(--amber);
  }

  .ask-subhead {
    font-size: clamp(0.9rem, 1.5vw, 1.0625rem);
    color: var(--fg-muted);
    line-height: 1.65;
    grid-column: 2;
    grid-row: 2;
    margin-top: 0.75rem;
    max-width: 44rem;
  }

  /* ── Controls: chips + input bar ────────────────────────── */
  .ask-controls {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
    margin-bottom: clamp(1.5rem, 3vw, 2rem);
  }

  .ask-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .ask-chip {
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--amber);
    background: transparent;
    border: 1px solid color-mix(in oklch, var(--amber) 40%, transparent);
    padding: 0.35rem 0.75rem;
    cursor: pointer;
    transition: background 0.2s ease, color 0.2s ease;
    text-align: left;
    line-height: 1.35;
    white-space: nowrap;
  }

  .ask-chip:hover {
    background: color-mix(in oklch, var(--amber) 12%, transparent);
    border-color: var(--amber);
  }

  /* Full-width input bar */
  .ask-input-row {
    display: flex;
  }

  .ask-input-field {
    flex: 1;
    background: var(--surface-raised, oklch(0.16 0.009 58));
    border: 1px solid var(--border-strong);
    border-right: none;
    color: var(--cream);
    font-size: 1.0625rem;
    font-family: inherit;
    padding: 0.9375rem 1.25rem;
    height: 3.5rem;
    outline: none;
    transition: border-color 0.2s ease;
    min-width: 0;
  }

  .ask-input-field::placeholder {
    color: var(--fg-subtle);
  }

  .ask-input-field:focus {
    border-color: var(--amber);
  }

  .ask-send-btn {
    background: var(--amber);
    color: oklch(0.08 0.008 60);
    border: none;
    width: 3.5rem;
    height: 3.5rem;
    flex-shrink: 0;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 0.2s ease;
  }

  .ask-send-btn:disabled {
    opacity: 0.35;
    cursor: not-allowed;
  }

  .ask-send-btn:not(:disabled):hover {
    opacity: 0.85;
  }

  .ask-status {
    font-size: 0.75rem;
    color: var(--fg-subtle);
    min-height: 1.2em;
    line-height: 1.4;
  }

  /* ── 3-panel full-width grid ─────────────────────────────── */
  .ask-panels {
    display: grid;
    grid-template-columns: 1.8fr 1fr 1fr;
    gap: 1rem;
    align-items: stretch;
  }

  .ask-panel {
    background: var(--surface, oklch(0.12 0.008 60));
    border: 1px solid var(--border);
    padding: 1.25rem 1.5rem;
    position: relative;
    overflow: hidden;
    min-height: clamp(360px, 36vw, 500px);
  }

  .ask-panel::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--amber), transparent);
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .ask-panel:hover::before { opacity: 1; }

  .panel-tag {
    display: block;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--fg-muted);
    margin-bottom: 0.75rem;
  }

  /* ── Panel 1: answer ─────────────────────────────────────── */
  .panel-answer {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .answer-text {
    font-size: clamp(0.9375rem, 1.2vw, 1.0625rem);
    color: var(--fg);
    line-height: 1.7;
    flex: 1;
  }

  :global(.hl) {
    color: var(--amber);
    font-weight: 600;
  }

  .ai-dots {
    display: none;
    gap: 3px;
    align-items: center;
  }

  .dot-anim {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--amber);
    opacity: 0.5;
    animation: dotPulse 1.4s ease-in-out infinite;
  }

  .dot-anim:nth-child(2) { animation-delay: 0.2s; }
  .dot-anim:nth-child(3) { animation-delay: 0.4s; }

  @keyframes dotPulse {
    0%, 80%, 100% { transform: scale(0.7); opacity: 0.3; }
    40%           { transform: scale(1);   opacity: 1; }
  }

  /* ── Panels 2 & 3: image + chart ─────────────────────────── */
  .panel-image,
  .panel-chart {
    display: flex;
    flex-direction: column;
  }

  .image-wrap {
    position: relative;
    flex: 1;
    overflow: hidden;
  }

  .generated-visual {
    display: none;
    flex-direction: column;
    gap: 0.4rem;
    padding: 0.5rem 0.75rem;
    width: 100%;
    height: 100%;
    overflow: hidden;
    position: relative;
  }

  .generated-visual:has(> .vis-photo) {
    padding: 0;
  }

  /* ── Pexels photo (dynamically injected — must be :global) */
  :global(.vis-photo) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    border-radius: 2px;
  }

  :global(.vis-photo-credit) {
    position: absolute;
    bottom: 0.4rem;
    right: 0.6rem;
    font-size: 0.6rem;
    color: rgba(255,255,255,0.45);
    line-height: 1.3;
  }

  :global(.vis-photo-credit a) {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  /* ── Stat card inner elements (dynamically injected via innerHTML — must be :global) */
  :global(.vis-question) {
    font-size: 0.75rem;
    color: var(--fg-muted);
    font-style: italic;
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  :global(.vis-hero) {
    text-align: center;
    padding: 0.25rem 0 0.35rem;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }

  :global(.vis-hero-value) {
    font-size: 2rem;
    font-weight: 700;
    color: var(--amber);
    line-height: 1;
    letter-spacing: -0.02em;
  }

  :global(.vis-hero-label) {
    font-size: 0.75rem;
    color: var(--fg);
    margin-top: 0.25rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  :global(.vis-bars) {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    flex: 1;
    overflow: hidden;
    justify-content: center;
  }

  :global(.vis-bar-row) {
    display: grid;
    grid-template-columns: 5rem 1fr 3.2rem;
    gap: 0.4rem;
    align-items: center;
  }

  :global(.vis-bar-label) {
    font-size: 0.75rem;
    color: var(--fg);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  :global(.vis-bar-track) {
    height: 7px;
    background: rgba(255,255,255,0.1);
    border-radius: 3px;
    overflow: hidden;
  }

  :global(.vis-bar-fill) {
    height: 100%;
    background: var(--amber, #d49820);
    border-radius: 3px;
  }

  :global(.vis-bar-value) {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--fg);
    white-space: nowrap;
    text-align: right;
  }

  .chart-title {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--fg);
    margin: 0 0 0.5rem;
    line-height: 1.3;
  }

  .chart-wrap {
    position: relative;
    flex: 1;
    min-height: 0;
    overflow: hidden;
  }

  #answer-chart {
    position: absolute;
    inset: 0;
    width: 100% !important;
    height: 100% !important;
    display: none;
  }

  /* ── Panel error states ──────────────────────────────────── */
  .panel-error {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 1rem;
    text-align: center;
    background: var(--surface);
    border: 1px dashed color-mix(in oklch, var(--amber) 30%, transparent);
  }

  /* For panel-answer the error sits in flow, not absolute */
  #panel-answer .panel-error {
    position: static;
    border: none;
    padding: 0.25rem 0;
    align-items: flex-start;
    text-align: left;
    background: transparent;
    flex-direction: row;
    gap: 0.5rem;
  }

  .panel-error-icon {
    font-size: 1rem;
    opacity: 0.5;
    flex-shrink: 0;
    line-height: 1.5;
  }

  .panel-error-msg {
    font-size: 0.75rem;
    color: var(--fg-muted);
    line-height: 1.55;
  }

  /* ── Skeleton generation status ─────────────────────────── */
  .skeleton-status {
    position: absolute;
    bottom: 1rem;
    left: 0;
    right: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    z-index: 1;
  }

  .skeleton-label {
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--fg-subtle);
  }

  .skeleton-sep {
    color: var(--border-strong);
    font-size: 0.75rem;
  }

  .skeleton-timer {
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: var(--amber);
    font-variant-numeric: tabular-nums;
    min-width: 2ch;
  }

  /* ── Skeleton shimmer ────────────────────────────────────── */
  .panel-skeleton {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      90deg,
      var(--surface) 0%,
      var(--surface-raised) 50%,
      var(--surface) 100%
    );
    background-size: 200% 100%;
    animation: shimmer 1.8s ease-in-out infinite;
  }

  .panel-skeleton.skeleton-error {
    animation: none;
    background: var(--surface);
    display: flex !important;
    align-items: center;
    justify-content: center;
  }

  .panel-skeleton.skeleton-error::after {
    content: '⚠';
    font-size: 1.5rem;
    opacity: 0.3;
  }

  @keyframes shimmer {
    0%   { background-position: -200% 0; }
    100% { background-position:  200% 0; }
  }

  /* ── Tablet: 2-column panels ─────────────────────────────── */
  @media (max-width: 1023px) and (min-width: 640px) {
    .ask-panels {
      grid-template-columns: 1fr 1fr;
    }

    #panel-answer {
      grid-column: 1 / -1;
      min-height: clamp(220px, 24vw, 320px);
    }
  }

  /* ── Mobile ──────────────────────────────────────────────── */
  @media (max-width: 639px) {
    .ask-panels {
      grid-template-columns: 1fr;
    }

    .ask-panel {
      min-height: clamp(280px, 70vw, 380px);
    }

    #panel-answer {
      min-height: clamp(200px, 50vw, 280px);
    }

    .ask-chips {
      flex-wrap: nowrap;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      padding-bottom: 0.25rem;
    }

    .ask-chips::-webkit-scrollbar { display: none; }
  }
</style>
