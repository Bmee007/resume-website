---
// ExperienceSection.astro — Typographic timeline redesign
const experiences = [
  {
    title: "AI & Agent Systems Lead",
    company: "Kohl and Frisch",
    dateRange: "2023 – Present",
    featured: false,
    bullets: [
      "Designed and deployed multi-step agentic workflows with custom skills and harness architecture, automating <em>16 operational processes</em> across finance and supply chain",
      "Built LLM-powered demand forecasting agents integrating ERP supply chain data, achieving <em>13% forecast accuracy improvement</em>",
      "Researching LLM memory patterns (episodic, semantic, working) and agent security threat models including prompt injection and privilege escalation",
    ],
  },
  {
    title: "AI & ERP Integration Lead — Supply Chain Transformation",
    company: "Kohl and Frisch",
    dateRange: "2019 – 2023",
    featured: true,
    bullets: [
      "Directed end-to-end ERP modernization for <em>Kohl &amp; Frisch</em> and enterprise supply chain clients, reducing operational costs by <em>30%</em>",
      "Integrated AI procurement agents into ERP workflows, reducing purchase cycle time by <em>33%</em>",
      "Led <em>45-person</em> cross-functional team through 18-month platform migration and AI augmentation program",
    ],
  },
  {
    title: "WMS & Operations AI Lead — Warehouse Intelligence",
    company: "Kohl and Frisch",
    dateRange: "2016 – 2019",
    featured: true,
    bullets: [
      "Deployed intelligent WMS across <em>9 distribution centers</em>, integrating AI pick optimization and increasing throughput by <em>15%</em>",
      "Applied ML-driven operations models to reduce labor costs by <em>5%</em> while improving pick accuracy to <em>99.7%</em>",
      "Partnered with C-suite to align warehouse AI roadmap with 5-year supply chain and retail fulfillment strategy",
    ],
  },
];
---

<section id="experience" class="exp-root">

  <span class="section-num" aria-hidden="true">03</span>

  <div class="exp-container">

    <div class="exp-header" data-reveal-heading>
      <span class="eyebrow-accent">Career</span>
      <h2 class="display-serif exp-heading">Experience</h2>
      <p class="exp-tagline">Quantified impact across AI engineering, supply chain, and enterprise operations</p>
    </div>

    <div class="timeline">
      {experiences.map((entry) => (
        <div class:list={["timeline-entry", entry.featured && "is-featured"]} data-reveal>
          <div class="entry-year" aria-hidden="true">
            {entry.dateRange.split('–')[0].trim()}
          </div>
          <div class="entry-card">
            <div class="entry-inner">
              <div class="entry-header">
                <span class="entry-company">{entry.company}</span>
                <span class="entry-dates">{entry.dateRange}</span>
              </div>
              <h3 class="entry-title">{entry.title}</h3>
              <ul class="entry-bullets">
                {entry.bullets.map((bullet) => (
                  <li set:html={bullet}></li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  .exp-root {
    position: relative;
    padding: clamp(6rem, 10vw, 9rem) clamp(1.5rem, 5vw, 4rem);
    overflow: hidden;
    background-image: url('/images/Background 4.png');
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }

  .exp-root::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom,
      var(--background) 0%,
      oklch(0.07 0.007 58 / 0.82) 14%,
      oklch(0.07 0.007 58 / 0.82) 86%,
      var(--background) 100%
    );
    pointer-events: none;
    z-index: 0;
  }

  .exp-container {
    max-width: 80rem;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  /* ── Header ───────────────────────────────────────────────── */
  .exp-header {
    margin-bottom: clamp(3rem, 5vw, 5rem);
  }

  .exp-heading {
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    margin: 0 0 0.75rem;
  }

  .exp-tagline {
    font-size: 1rem;
    color: var(--fg-muted);
    margin: 0;
  }

  /* ── Timeline ─────────────────────────────────────────────── */
  .timeline {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .timeline-entry {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
    position: relative;
  }

  @media (min-width: 640px) {
    .timeline-entry {
      grid-template-columns: 5rem 1fr;
      gap: 1.5rem;
      align-items: start;
    }
  }

  /* ── Year anchor ──────────────────────────────────────────── */
  .entry-year {
    font-family: "DM Serif Display", Georgia, serif;
    font-style: italic;
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    color: oklch(0.22 0.010 55);
    letter-spacing: -0.03em;
    line-height: 1;
    padding-top: 1.5rem;
    transition: color 0.3s ease;
    display: none;
  }

  @media (min-width: 640px) {
    .entry-year {
      display: block;
      text-align: right;
    }
  }

  .timeline-entry:hover .entry-year {
    color: var(--amber);
  }

  .timeline-entry.is-featured .entry-year {
    color: color-mix(in oklch, var(--amber) 50%, oklch(0.22 0.010 55));
  }

  .timeline-entry.is-featured:hover .entry-year {
    color: var(--amber);
  }

  /* ── Entry card ───────────────────────────────────────────── */
  .entry-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 0.75rem;
    transition:
      border-color 0.25s var(--ease-expo-out),
      transform    0.25s var(--ease-expo-out),
      box-shadow   0.25s var(--ease-expo-out);
  }

  .entry-card:hover {
    border-color: var(--border-strong);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.3);
  }

  .timeline-entry.is-featured .entry-card {
    border-left: 2px solid var(--amber);
    box-shadow: inset 2px 0 20px color-mix(in oklch, var(--amber) 6%, transparent);
  }

  .entry-inner {
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }

  /* ── Entry meta ───────────────────────────────────────────── */
  .entry-header {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    flex-wrap: wrap;
  }

  .entry-company {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--fg-subtle);
  }

  .entry-dates {
    font-size: 0.8125rem;
    color: var(--amber);
    font-weight: 500;
    letter-spacing: 0.02em;
  }

  .entry-title {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--cream);
    margin: 0;
    line-height: 1.35;
    letter-spacing: -0.01em;
  }

  /* ── Bullets ──────────────────────────────────────────────── */
  .entry-bullets {
    margin: 0;
    padding-left: 1.125rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .entry-bullets li {
    font-size: 0.9375rem;
    color: var(--fg-muted);
    line-height: 1.7;
  }

  /* Highlighted metric numbers */
  .entry-bullets li :global(em) {
    font-style: normal;
    color: var(--cream);
    font-weight: 500;
  }

  /* ── Reveal ───────────────────────────────────────────────── */
  [data-reveal] {
    opacity: 0;
    transform: translateY(28px);
    transition:
      opacity   0.7s var(--ease-expo-out),
      transform 0.7s var(--ease-expo-out);
  }

  [data-reveal].is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  [data-reveal-heading] {
    opacity: 0;
    transform: translateX(-20px);
    transition:
      opacity   0.8s var(--ease-expo-out),
      transform 0.8s var(--ease-expo-out);
  }

  [data-reveal-heading].is-visible {
    opacity: 1;
    transform: translateX(0);
  }

  @media (prefers-reduced-motion: reduce) {
    [data-reveal],
    [data-reveal-heading] {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>
