---
const experiences = [
  {
    title: "AI & ERP Integration Lead",
    company: "Kohl and Frisch",
    dateRange: "2023 – Present",
    featured: false,
    bgColor: "#1e3a8a",
    bullets: [
      "Architected Power Automate + AI Builder workflows, automating 16 manual processes across finance and ops",
      "Led Azure OpenAI pilot for supply chain demand forecasting, achieving 12% forecast accuracy improvement",
    ],
  },
  {
    title: "ERP Implementation Lead — D365 Migration",
    company: "Kohl and Frisch",
    dateRange: "2019 – 2023",
    featured: true,
    bullets: [
      "Directed full Microsoft Dynamics 365 migration from IBM AS400, cutting operational costs by 30%",
      "Integrated Azure OpenAI into D365 procurement workflows, reducing cycle time by 33%",
      "Led 45-person cross-functional team through 18-month ERP modernization program",
    ],
  },
  {
    title: "WMS Implementation Lead — Manhattan DFIO",
    company: "Kohl and Frisch",
    dateRange: "2016 – 2019",
    featured: true,
    bullets: [
      "Deployed Manhattan DFIO across 9 distribution centers, increasing warehouse throughput by 15%",
      "Integrated AI-driven pick optimization into Manhattan DFIO, reducing labor costs by 5%",
      "Partnered with C-suite stakeholders to align WMS roadmap with 5-year supply chain strategy",
    ],
  },
];
---

<section id="experience" class="exp-root">

  <!-- Background layer -->
  <div class="section-bg" aria-hidden="true"></div>

  <div class="exp-container section-animate">
    <div class="exp-header">
      <h2>Experience</h2>
      <p class="exp-tagline">Quantified impact across ERP, WMS, and AI transformation</p>
    </div>

    <div class="timeline-track">
      {experiences.map((entry) => (
        <div class:list={["timeline-entry", entry.featured && "is-featured"]}>
          <div class:list={["entry-card rounded-2xl", entry.featured ? "liquid-glass" : "entry-card--flat"]} style={entry.bgColor ? `background: ${entry.bgColor}; border-color: ${entry.bgColor};` : ""}>
            <div class="entry-inner">
              <div class="entry-header">
                <h3 class="entry-title">{entry.title}</h3>
                <div class="entry-meta">
                  <span class="entry-company">{entry.company}</span>
                  <span class="entry-dates">{entry.dateRange}</span>
                </div>
              </div>
              <ul class="entry-bullets">
                {entry.bullets.map((bullet) => (
                  <li>{bullet}</li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  /* ── Scroll-triggered reveal ──────────────────────────── */
  .section-animate {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 500ms ease, transform 500ms ease;
  }
  .section-animate.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
  @media (prefers-reduced-motion: reduce) {
    .section-animate {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }

  /* Section shell — mirrors SkillsSection padding/container pattern */
  .exp-root { padding: 5rem 1.5rem; min-height: 100vh; position: relative; overflow: hidden; }
  .exp-container { max-width: 72rem; margin: 0 auto; position: relative; z-index: 1; }

  /* ── Background layer ─────────────────────────────────── */
  @keyframes bg-slide-up {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 0.5; transform: translateY(0); }
  }

  .section-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    background-image: url('/images/bg-experience.jpg');
    background-size: cover;
    background-position: center;
    opacity: 0;
  }

  .section-bg.is-visible {
    animation: bg-slide-up 0.8s ease forwards;
  }

  @media (prefers-reduced-motion: reduce) {
    .section-bg.is-visible {
      animation: none;
      opacity: 0.5;
      transform: translateY(0);
    }
  }
  .exp-header { margin-bottom: 3rem; text-align: center; }
  .exp-header h2 { font-size: clamp(1.75rem, 4vw, 2.75rem); font-weight: 600; color: hsl(var(--foreground)); margin: 0; }
  .exp-tagline { font-size: 1.125rem; color: hsl(var(--foreground) / 0.6); margin-top: 0.5rem; margin-bottom: 0; }

  /* Timeline track */
  .timeline-track {
    position: relative;
    padding-left: 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  /* Vertical connecting line */
  .timeline-track::before {
    content: '';
    position: absolute;
    left: 0.5rem;
    top: 1.25rem;
    bottom: 1.25rem;
    width: 2px;
    background: hsl(var(--border-hsl));
  }

  /* Entry dot */
  .timeline-entry {
    position: relative;
  }

  .timeline-entry::before {
    content: '';
    position: absolute;
    left: -2.125rem;
    top: 1.125rem;
    width: 0.625rem;
    height: 0.625rem;
    border-radius: 9999px;
    background: hsl(var(--primary));
    z-index: 1;
  }

  /* Pulse animation on featured entry dot */
  .timeline-entry.is-featured::before {
    box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.5);
    animation: dot-pulse 2.5s ease-in-out infinite;
  }

  @keyframes dot-pulse {
    0%   { box-shadow: 0 0 0 0   rgba(16, 185, 129, 0.5); }
    50%  { box-shadow: 0 0 0 6px rgba(16, 185, 129, 0); }
    100% { box-shadow: 0 0 0 0   rgba(16, 185, 129, 0); }
  }

  /* Card hover: lift + emerald glow */
  .entry-card {
    transition: transform 200ms ease, box-shadow 200ms ease;
  }

  .entry-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 0 12px rgba(16, 185, 129, 0.35);
  }

  /* Flat card for regular entries */
  .entry-card--flat {
    background: #1E293B;
    border: 1px solid #334155;
    border-radius: 1rem;
  }

  /* Emerald left-border stripe for featured entries */
  .is-featured .entry-card {
    border-left: 3px solid #10B981;
  }

  /* Inner wrapper — z-index:1 prevents content hidden behind liquid-glass::before */
  .entry-inner {
    position: relative;
    z-index: 1;
    padding: 1.75rem;
  }

  /* Entry header and content */
  .entry-header { margin-bottom: 1rem; }
  .entry-title { font-size: 1.125rem; font-weight: 600; color: hsl(var(--foreground)); margin: 0 0 0.25rem; }
  .entry-meta { display: flex; flex-wrap: wrap; gap: 0.5rem 1rem; align-items: center; }
  .entry-company { font-size: 0.9375rem; color: hsl(var(--foreground) / 0.7); }
  .entry-dates { font-size: 0.875rem; color: hsl(var(--foreground) / 0.5); }
  .entry-bullets { margin: 0; padding-left: 1.25rem; display: flex; flex-direction: column; gap: 0.5rem; }
  .entry-bullets li { font-size: 0.9375rem; color: hsl(var(--foreground) / 0.8); line-height: 1.6; }
</style>

<script>
  const expBgObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          expBgObserver.unobserve(entry.target);
        }
      });
    },
    { rootMargin: '-10% 0px -10% 0px', threshold: 0 }
  );
  document.querySelectorAll('#experience .section-bg').forEach((el) => expBgObserver.observe(el));
</script>
