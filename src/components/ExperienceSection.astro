---
const experiences = [
  {
    title: "AI & ERP Integration Lead",
    company: "Kohl and Frisch",
    dateRange: "2023 – Present",
    featured: false,
    bullets: [
      "Architected Power Automate + AI Builder workflows, automating 16 manual processes across finance and ops",
      "Led Azure OpenAI pilot for supply chain demand forecasting, achieving 12% forecast accuracy improvement",
    ],
  },
  {
    title: "ERP Implementation Lead — D365 Migration",
    company: "Kohl and Frisch",
    dateRange: "2019 – 2023",
    featured: true,
    bullets: [
      "Directed full Microsoft Dynamics 365 migration from IBM AS400, cutting operational costs by 30%",
      "Integrated Azure OpenAI into D365 procurement workflows, reducing cycle time by 33%",
      "Led 45-person cross-functional team through 18-month ERP modernization program",
    ],
  },
  {
    title: "WMS Implementation Lead — Manhattan DFIO",
    company: "Kohl and Frisch",
    dateRange: "2016 – 2019",
    featured: true,
    bullets: [
      "Deployed Manhattan DFIO across 9 distribution centers, increasing warehouse throughput by 15%",
      "Integrated AI-driven pick optimization into Manhattan DFIO, reducing labor costs by 5%",
      "Partnered with C-suite stakeholders to align WMS roadmap with 5-year supply chain strategy",
    ],
  },
];
---

<section id="experience" class="exp-root">
  <div class="exp-container section-animate">

    <div class="exp-header">
      <p class="section-eyebrow">Career</p>
      <h2>Experience</h2>
      <p class="exp-tagline">Quantified impact across ERP, WMS, and AI transformation</p>
    </div>

    <div class="timeline-track">
      {experiences.map((entry) => (
        <div class:list={["timeline-entry", entry.featured && "is-featured"]}>
          <div class:list={["entry-card", entry.featured ? "entry-card--featured" : "entry-card--standard"]}>
            <div class="entry-inner">
              <div class="entry-header">
                <h3 class="entry-title">{entry.title}</h3>
                <div class="entry-meta">
                  <span class="entry-company">{entry.company}</span>
                  <span class="entry-sep" aria-hidden="true">·</span>
                  <span class="entry-dates">{entry.dateRange}</span>
                </div>
              </div>
              <ul class="entry-bullets">
                {entry.bullets.map((bullet) => (
                  <li>{bullet}</li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  .section-animate {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 600ms var(--ease-expo-out, ease),
                transform 600ms var(--ease-expo-out, ease);
  }
  .section-animate.is-visible { opacity: 1; transform: translateY(0); }
  @media (prefers-reduced-motion: reduce) {
    .section-animate { opacity: 1; transform: none; transition: none; }
  }

  .exp-root {
    padding: clamp(4rem, 8vw, 7rem) clamp(1.5rem, 4vw, 3rem);
  }

  .exp-container {
    max-width: 72rem;
    margin: 0 auto;
  }

  /* ── Header ───────────────────────────────────────────────── */
  .section-eyebrow {
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--primary);
    margin: 0 0 1rem;
  }

  .exp-header {
    margin-bottom: 3rem;
  }

  .exp-header h2 {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 600;
    color: var(--foreground);
    margin: 0 0 0.5rem;
    letter-spacing: -0.02em;
  }

  .exp-tagline {
    font-size: 1rem;
    color: var(--fg-muted);
    margin: 0;
  }

  /* ── Timeline ─────────────────────────────────────────────── */
  .timeline-track {
    position: relative;
    padding-left: 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .timeline-track::before {
    content: '';
    position: absolute;
    left: 0.5rem;
    top: 1.25rem;
    bottom: 1.25rem;
    width: 1px;
    background: var(--border);
  }

  /* Entry dot */
  .timeline-entry {
    position: relative;
  }

  .timeline-entry::before {
    content: '';
    position: absolute;
    left: -2.125rem;
    top: 1.25rem;
    width: 7px;
    height: 7px;
    border-radius: 9999px;
    background: var(--border);
    z-index: 1;
    transition: background 0.2s;
  }

  .timeline-entry.is-featured::before {
    background: var(--primary);
  }

  /* Cards */
  .entry-card {
    border-radius: 0.5rem;
    transition: border-color 0.25s var(--ease-expo-out, ease);
  }

  .entry-card--standard {
    background: var(--secondary);
    border: 1px solid var(--border);
  }

  .entry-card--featured {
    background: var(--secondary);
    border: 1px solid var(--border);
    border-left: 2px solid var(--primary);
  }

  .entry-card:hover {
    border-color: color-mix(in oklch, var(--primary) 40%, var(--border));
  }

  .entry-card--featured:hover {
    border-left-color: var(--primary);
  }

  .entry-inner {
    padding: 1.75rem;
  }

  .entry-header { margin-bottom: 1rem; }

  .entry-title {
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--foreground);
    margin: 0 0 0.375rem;
  }

  .entry-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.375rem 0.625rem;
  }

  .entry-company {
    font-size: 0.9375rem;
    color: var(--fg-muted);
  }

  .entry-sep {
    color: var(--fg-subtle);
    font-size: 0.75rem;
  }

  .entry-dates {
    font-size: 0.875rem;
    color: var(--primary);
    font-weight: 500;
  }

  .entry-bullets {
    margin: 0;
    padding-left: 1.125rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .entry-bullets li {
    font-size: 0.9375rem;
    color: var(--fg-muted);
    line-height: 1.65;
  }
</style>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { rootMargin: '-10% 0px -10% 0px', threshold: 0 }
  );
  document.querySelectorAll('#experience .section-animate').forEach((el) => observer.observe(el));
</script>
