---
---

<section id="contact" class="contact-root">
  <div class="contact-inner">
    <h2 class="contact-heading">Get In Touch</h2>
    <p class="contact-tagline">Open to consulting engagements and full-time opportunities</p>

    <div id="contact-card" class="contact-card liquid-glass">
      <form id="contact-form" novalidate data-formspree-id="xdawllej">
        <div class="field-group">
          <input
            id="cf-name"
            name="name"
            type="text"
            placeholder="Your name"
            autocomplete="name"
            required
          />
          <span id="error-name" class="field-error" aria-live="polite"></span>
        </div>

        <div class="field-group">
          <input
            id="cf-email"
            name="email"
            type="email"
            placeholder="your@email.com"
            autocomplete="email"
            required
          />
          <span id="error-email" class="field-error" aria-live="polite"></span>
        </div>

        <div class="field-group">
          <textarea
            id="cf-message"
            name="message"
            placeholder="What can I help you with?"
            rows="5"
            required
          ></textarea>
          <span id="error-message" class="field-error" aria-live="polite"></span>
        </div>

        <button type="submit" class="btn-hero rounded-full contact-submit">Send Message</button>
      </form>

      <div id="contact-success" class="contact-success" hidden aria-live="polite">
        <p>Message sent. I'll be in touch soon.</p>
      </div>
    </div>

    <div class="contact-social">
      <a
        href="https://www.linkedin.com/in/borinakeo"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="LinkedIn profile"
        class="social-icon-link"
      >
        <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
      </a>
      <a
        href="https://github.com/Bmee007"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="GitHub profile"
        class="social-icon-link"
      >
        <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
        </svg>
      </a>
    </div>

    <footer class="site-footer">
      <p>&copy; 2025 Borina Keo</p>
    </footer>
  </div>
</section>

<style>
  /* Layout */
  .contact-root {
    padding: 6rem 1.5rem;
  }

  .contact-inner {
    max-width: 600px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
  }

  .contact-heading {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700;
    text-align: center;
  }

  .contact-tagline {
    color: hsl(var(--secondary));
    text-align: center;
    font-size: 1rem;
  }

  /* Card */
  .contact-card {
    width: 100%;
    position: relative;
    border-radius: 1rem;
    padding: 2.5rem;
  }

  /* CRITICAL z-index fix: content must render above liquid-glass::before pseudo-element (z-index:0) */
  #contact-form,
  .contact-success {
    position: relative;
    z-index: 1;
  }

  /* Fields */
  .field-group {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    margin-bottom: 1.25rem;
  }

  input,
  textarea {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid hsl(var(--border-hsl) / 0.3);
    border-radius: 0.5rem;
    padding: 0.75rem 1rem;
    color: hsl(var(--foreground));
    font-size: 1rem;
    width: 100%;
    font-family: inherit;
  }

  input:focus,
  textarea:focus {
    outline: none;
    border-color: #10b981;
    box-shadow: 0 0 0 2px rgba(16, 185, 129, 0.25), 0 0 8px rgba(16, 185, 129, 0.2);
  }

  textarea {
    resize: vertical;
    min-height: 120px;
  }

  /* Error states */
  input.is-invalid,
  textarea.is-invalid {
    border-color: #ef4444;
    box-shadow: 0 0 0 2px rgba(239, 68, 68, 0.25);
  }

  .field-error {
    display: block;
    font-size: 0.75rem;
    color: #ef4444;
    margin-top: 0.25rem;
    min-height: 1rem;
  }

  /* Submit button — full-width override */
  .contact-submit {
    width: 100%;
    margin-top: 0.5rem;
  }

  /* Success panel */
  .contact-success {
    text-align: center;
    padding: 2rem 0;
    font-size: 1.1rem;
    color: hsl(var(--foreground));
  }

  /* Social links */
  .contact-social {
    display: flex;
    gap: 1.25rem;
    justify-content: center;
  }

  /* Social icon links — declared locally (Astro scoped styles do not share across components) */
  .social-icon-link {
    color: hsl(var(--secondary));
    transition: color 0.2s ease;
  }

  .social-icon-link:hover {
    color: #10b981;
  }

  /* Footer */
  .site-footer {
    text-align: center;
    color: hsl(var(--secondary));
    font-size: 0.875rem;
    opacity: 0.6;
    margin-top: 1rem;
  }
</style>

<script>
  const FORMSPREE_ID = "xdawllej";

  const form = document.getElementById("contact-form") as HTMLFormElement | null;
  const submitBtn = form?.querySelector<HTMLButtonElement>('button[type="submit"]');
  const successPanel = document.getElementById("contact-success");

  const nameInput = document.getElementById("cf-name") as HTMLInputElement | null;
  const emailInput = document.getElementById("cf-email") as HTMLInputElement | null;
  const messageInput = document.getElementById("cf-message") as HTMLTextAreaElement | null;

  const errorName = document.getElementById("error-name");
  const errorEmail = document.getElementById("error-email");
  const errorMessage = document.getElementById("error-message");

  function clearErrors() {
    [nameInput, emailInput, messageInput].forEach((el) => el?.classList.remove("is-invalid"));
    if (errorName) errorName.textContent = "";
    if (errorEmail) errorEmail.textContent = "";
    if (errorMessage) errorMessage.textContent = "";
  }

  function validateForm(): boolean {
    let valid = true;

    if (!nameInput?.value.trim()) {
      nameInput?.classList.add("is-invalid");
      if (errorName) errorName.textContent = "Name is required";
      valid = false;
    }

    const emailVal = emailInput?.value.trim() ?? "";
    const emailPattern = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    if (!emailVal || !emailPattern.test(emailVal)) {
      emailInput?.classList.add("is-invalid");
      if (errorEmail) errorEmail.textContent = "Please enter a valid email";
      valid = false;
    }

    if (!messageInput?.value.trim()) {
      messageInput?.classList.add("is-invalid");
      if (errorMessage) errorMessage.textContent = "Message is required";
      valid = false;
    }

    return valid;
  }

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    clearErrors();

    if (!validateForm()) return;

    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.textContent = "Sending\u2026";
    }

    try {
      const response = await fetch(`https://formspree.io/f/${FORMSPREE_ID}`, {
        method: "POST",
        headers: {
          Accept: "application/json",
        },
        body: new FormData(form!),
      });

      if (response.ok) {
        // Fade form out over 300ms, then hide and show success
        if (form) {
          form.style.transition = "opacity 0.3s ease";
          form.style.opacity = "0";
          setTimeout(() => {
            form.hidden = true;
            if (successPanel) {
              successPanel.hidden = false;
              successPanel.style.opacity = "0";
              successPanel.style.transition = "opacity 0.3s ease";
              // Force reflow before starting fade in
              void successPanel.offsetHeight;
              successPanel.style.opacity = "1";
            }
          }, 300);
        }
      } else {
        // Server-side error — show under email field
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.textContent = "Send Message";
        }
        if (errorEmail) errorEmail.textContent = "Something went wrong. Please try again.";
        emailInput?.classList.add("is-invalid");
      }
    } catch {
      // Network error — show under message field
      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.textContent = "Send Message";
      }
      if (errorMessage) errorMessage.textContent = "Network error. Please try again.";
      messageInput?.classList.add("is-invalid");
    }
  });
</script>
