---
// ContactSection.astro — Split layout redesign
---

<section id="contact" class="contact-root">

  <span class="section-num" aria-hidden="true">05</span>

  <div class="contact-container">

    <!-- Left: editorial heading -->
    <div class="contact-left" data-reveal-heading>
      <span class="eyebrow-accent">Contact</span>
      <h2 class="display-serif contact-heading">
        Let's<br/>build<br/>something.
      </h2>
      <p class="contact-body">
        Open to consulting on AI agent systems, supply chain and healthcare integrations,
        LLM memory and security research, and full-time AI engineering roles.
      </p>
      <div class="contact-social">
        <a
          href="https://www.linkedin.com/in/borinakeo"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="LinkedIn profile"
          class="social-icon-link"
          data-cursor-hover
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </a>
        <a
          href="https://github.com/Bmee007"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="GitHub profile"
          class="social-icon-link"
          data-cursor-hover
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
          </svg>
        </a>
      </div>
    </div>

    <!-- Right: form -->
    <div class="contact-right" data-reveal>
      <div id="contact-card" class="contact-form-card">
        <form id="contact-form" novalidate data-formspree-id="xdawllej">
          <div class="field-group">
            <label for="cf-name" class="field-label">Name</label>
            <input
              id="cf-name"
              name="name"
              type="text"
              placeholder="Your name"
              autocomplete="name"
              required
            />
            <span id="error-name" class="field-error" aria-live="polite"></span>
          </div>

          <div class="field-group">
            <label for="cf-email" class="field-label">Email</label>
            <input
              id="cf-email"
              name="email"
              type="email"
              placeholder="your@email.com"
              autocomplete="email"
              required
            />
            <span id="error-email" class="field-error" aria-live="polite"></span>
          </div>

          <div class="field-group">
            <label for="cf-message" class="field-label">Message</label>
            <textarea
              id="cf-message"
              name="message"
              placeholder="What can I help you with?"
              rows="5"
              required
            ></textarea>
            <span id="error-message" class="field-error" aria-live="polite"></span>
          </div>

          <button type="submit" class="btn-amber contact-submit" data-magnetic>
            <span>Send Message</span>
          </button>
        </form>

        <div id="contact-success" class="contact-success" hidden aria-live="polite">
          <p>Message sent. I'll be in touch soon.</p>
        </div>
      </div>
    </div>

  </div>

  <footer class="site-footer">
    <div class="footer-brand">
      <img src="/images/bk-logo.svg" alt="BK" class="footer-logo" />
      <span class="footer-name">Borina Keo</span>
    </div>
    <p class="footer-copy">&copy; 2026 · AI Systems Engineer · Agent Builder · Supply Chain AI</p>
  </footer>

</section>

<style>
  .contact-root {
    position: relative;
    padding: clamp(6rem, 10vw, 9rem) clamp(1.5rem, 5vw, 4rem) clamp(4rem, 6vw, 5rem);
    overflow: hidden;
  }

  .contact-container {
    max-width: 80rem;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
    position: relative;
    z-index: 1;
  }

  @media (min-width: 768px) {
    .contact-container {
      grid-template-columns: 1fr 1fr;
      gap: 6rem;
      align-items: start;
    }
  }

  /* ── Left ─────────────────────────────────────────────────── */
  .contact-left {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .contact-heading {
    font-size: clamp(2.75rem, 6vw, 5rem);
    margin: 0;
    line-height: 0.95;
  }

  .contact-body {
    font-size: 1rem;
    color: var(--fg-muted);
    line-height: 1.7;
    max-width: 28rem;
    margin: 0;
  }

  .contact-social {
    display: flex;
    gap: 1.25rem;
    align-items: center;
  }

  .social-icon-link {
    color: var(--fg-subtle);
    transition: color 0.2s ease, transform 0.2s ease;
    display: inline-flex;
  }

  .social-icon-link:hover {
    color: var(--amber);
    transform: translateY(-2px);
  }

  /* ── Right: form ──────────────────────────────────────────── */
  .contact-form-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 1rem;
    padding: 2.5rem;
  }

  /* ── Fields ───────────────────────────────────────────────── */
  .field-group {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    margin-bottom: 1.375rem;
  }

  .field-label {
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: var(--fg-muted);
    text-transform: uppercase;
  }

  input,
  textarea {
    background: var(--background);
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    padding: 0.75rem 1rem;
    color: var(--foreground);
    font-size: 0.9375rem;
    width: 100%;
    font-family: "Inter", sans-serif;
    transition: border-color 0.2s var(--ease-expo-out), box-shadow 0.2s;
  }

  input::placeholder,
  textarea::placeholder {
    color: var(--fg-subtle);
  }

  input:focus,
  textarea:focus {
    outline: none;
    border-color: var(--amber);
    box-shadow: 0 0 0 2px var(--amber-dim);
  }

  textarea {
    resize: vertical;
    min-height: 130px;
  }

  input.is-invalid,
  textarea.is-invalid {
    border-color: oklch(0.577 0.245 27.325);
    box-shadow: 0 0 0 2px color-mix(in oklch, oklch(0.577 0.245 27.325) 20%, transparent);
  }

  .field-error {
    display: block;
    font-size: 0.75rem;
    color: oklch(0.577 0.245 27.325);
    min-height: 1rem;
  }

  .contact-submit {
    width: 100%;
    margin-top: 0.5rem;
    padding: 0.875rem;
    font-size: 0.9375rem;
    justify-content: center;
    border-radius: 0.5rem;
  }

  .contact-success {
    text-align: center;
    padding: 2.5rem 0;
    font-size: 1rem;
    color: var(--foreground);
  }

  /* ── Footer ───────────────────────────────────────────────── */
  .site-footer {
    text-align: center;
    max-width: 80rem;
    margin: 4rem auto 0;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  .footer-brand {
    display: flex;
    align-items: center;
    gap: 0.625rem;
  }

  .footer-logo {
    width: 2rem;
    height: 2rem;
    filter: invert(55%) sepia(80%) saturate(600%) hue-rotate(355deg) brightness(105%);
    opacity: 0.7;
  }

  .footer-name {
    font-family: "Playfair Display", Georgia, serif;
    font-style: italic;
    font-size: 1.0625rem;
    color: var(--fg-muted);
    letter-spacing: -0.01em;
  }

  .footer-copy {
    font-size: 0.8125rem;
    color: var(--fg-subtle);
    letter-spacing: 0.04em;
    margin: 0;
  }

  /* ── Reveal ───────────────────────────────────────────────── */
  [data-reveal] {
    opacity: 0;
    transform: translateY(28px);
    transition:
      opacity   0.7s var(--ease-expo-out),
      transform 0.7s var(--ease-expo-out);
  }

  [data-reveal].is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  [data-reveal-heading] {
    opacity: 0;
    transform: translateX(-20px);
    transition:
      opacity   0.8s var(--ease-expo-out),
      transform 0.8s var(--ease-expo-out);
  }

  [data-reveal-heading].is-visible {
    opacity: 1;
    transform: translateX(0);
  }

  @media (prefers-reduced-motion: reduce) {
    [data-reveal],
    [data-reveal-heading] {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>

<script>
  const FORMSPREE_ID = "xdawllej";

  const form        = document.getElementById("contact-form") as HTMLFormElement | null;
  const submitBtn   = form?.querySelector<HTMLButtonElement>('button[type="submit"]');
  const successPanel = document.getElementById("contact-success");

  const nameInput    = document.getElementById("cf-name")    as HTMLInputElement | null;
  const emailInput   = document.getElementById("cf-email")   as HTMLInputElement | null;
  const messageInput = document.getElementById("cf-message") as HTMLTextAreaElement | null;

  const errorName    = document.getElementById("error-name");
  const errorEmail   = document.getElementById("error-email");
  const errorMessage = document.getElementById("error-message");

  function clearErrors() {
    [nameInput, emailInput, messageInput].forEach((el) => el?.classList.remove("is-invalid"));
    if (errorName)    errorName.textContent    = "";
    if (errorEmail)   errorEmail.textContent   = "";
    if (errorMessage) errorMessage.textContent = "";
  }

  function validateForm(): boolean {
    let valid = true;

    if (!nameInput?.value.trim()) {
      nameInput?.classList.add("is-invalid");
      if (errorName) errorName.textContent = "Name is required";
      valid = false;
    }

    const emailVal     = emailInput?.value.trim() ?? "";
    const emailPattern = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    if (!emailVal || !emailPattern.test(emailVal)) {
      emailInput?.classList.add("is-invalid");
      if (errorEmail) errorEmail.textContent = "Please enter a valid email";
      valid = false;
    }

    if (!messageInput?.value.trim()) {
      messageInput?.classList.add("is-invalid");
      if (errorMessage) errorMessage.textContent = "Message is required";
      valid = false;
    }

    return valid;
  }

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    clearErrors();

    if (!validateForm()) return;

    if (submitBtn) {
      submitBtn.disabled = true;
      const span = submitBtn.querySelector('span');
      if (span) span.textContent = "Sending\u2026";
    }

    try {
      const response = await fetch(`https://formspree.io/f/${FORMSPREE_ID}`, {
        method:  "POST",
        headers: { Accept: "application/json" },
        body:    new FormData(form!),
      });

      if (response.ok) {
        if (form) {
          form.style.transition = "opacity 0.3s ease";
          form.style.opacity    = "0";
          setTimeout(() => {
            form.hidden = true;
            if (successPanel) {
              successPanel.hidden           = false;
              successPanel.style.opacity    = "0";
              successPanel.style.transition = "opacity 0.3s ease";
              void successPanel.offsetHeight;
              successPanel.style.opacity    = "1";
            }
          }, 300);
        }
      } else {
        if (submitBtn) {
          submitBtn.disabled = false;
          const span = submitBtn.querySelector('span');
          if (span) span.textContent = "Send Message";
        }
        if (errorEmail) errorEmail.textContent = "Something went wrong. Please try again.";
        emailInput?.classList.add("is-invalid");
      }
    } catch {
      if (submitBtn) {
        submitBtn.disabled = false;
        const span = submitBtn.querySelector('span');
        if (span) span.textContent = "Send Message";
      }
      if (errorMessage) errorMessage.textContent = "Network error. Please try again.";
      messageInput?.classList.add("is-invalid");
    }
  });
</script>
