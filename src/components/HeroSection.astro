---
// HeroSection.astro — Dark luxury editorial redesign
const techs = [
  "Supply Chain AI",
  "Agent Engineering",
  "ERP · WMS · TMS",
  "LLM Memory Research",
  "Agent Security",
  "Healthcare Integration",
  "Retail Operations",
  "AI System Design",
  "Data Science",
  "Python · ML",
  "Agentic Workflows",
  "Claude · GPT-4o · Gemini",
  "Supply Chain AI",
  "Agent Engineering",
  "ERP · WMS · TMS",
  "LLM Memory Research",
  "Agent Security",
  "Healthcare Integration",
  "Retail Operations",
  "AI System Design",
  "Data Science",
  "Python · ML",
  "Agentic Workflows",
  "Claude · GPT-4o · Gemini",
];
---

<section id="hero" class="hero-root">

  <!-- Background image overlay system -->
  <div class="hero-bg" aria-hidden="true">
    <div class="hero-overlay"></div>
    <div class="hero-fade-bottom"></div>
  </div>

  <!-- Main content -->
  <div class="hero-content">

    <div class="hero-text">

      <!-- Role badge -->
      <div id="hero-label" class="hero-label">
        <span class="label-line" aria-hidden="true"></span>
        <span class="label-text">AI Systems Engineer · Agent Builder · Supply Chain AI</span>
      </div>

      <!-- Massive split-text name — GSAP animates chars -->
      <h1 id="hero-name" class="hero-name display-serif" aria-label="Borina Keo">
        Borina Keo
      </h1>

      <!-- Position descriptor -->
      <p id="hero-title" class="hero-title">
        Building intelligent agents across
        <em class="accent-word">Supply Chain, Healthcare, and Retail</em> —
        from ERP, WMS &amp; TMS integration to autonomous
        AI systems that think, act, and remember.
      </p>

      <!-- Tagline -->
      <p id="hero-sub" class="hero-sub">
        15+ years bridging data science and enterprise operations.
        Researching LLM memory architectures and agent security
        while deploying AI across Kohl &amp; Frisch and enterprise clients.
      </p>

      <!-- CTAs -->
      <div id="hero-ctas" class="hero-ctas">
        <a href="#contact" class="btn-amber" data-magnetic>
          <span>Let's Connect</span>
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a href="#about" class="btn-ghost" data-magnetic>
          View My Work
        </a>
      </div>

      <!-- Social links -->
      <div id="hero-social" class="hero-social">
        <a
          href="https://www.linkedin.com/in/borinakeo"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="LinkedIn profile"
          class="social-link"
          data-cursor-hover
        >LinkedIn</a>
        <span class="social-sep" aria-hidden="true">/</span>
        <a
          href="https://github.com/Bmee007"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="GitHub profile"
          class="social-link"
          data-cursor-hover
        >GitHub</a>
      </div>

    </div>

    <div class="hero-portrait-wrap" aria-hidden="true">
      <img
        src="/images/Profile.jpg"
        alt="Borina Keo"
        class="hero-portrait"
        loading="eager"
        decoding="async"
      />
    </div>

  </div>

  <!-- Scroll indicator -->
  <div class="scroll-indicator" aria-hidden="true">
    <span class="scroll-line"></span>
    <span class="scroll-label">scroll</span>
  </div>

  <!-- Tech marquee -->
  <div class="hero-marquee">
    <div class="marquee-viewport">
      <div class="marquee-track">
        {techs.map((tech) => (
          <span class="marquee-item">{tech}</span>
        ))}
      </div>
    </div>
  </div>

</section>

<style>
  /* ── Root ─────────────────────────────────────────────────── */
  .hero-root {
    position: relative;
    min-height: 100svh;
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    grid-template-rows: 1fr auto auto;
    overflow: hidden;
    background-image: url('/images/bg-hero.png');
    background-size: cover;
    background-position: center center;
    background-repeat: no-repeat;
  }

  /* ── Background overlay system ───────────────────────────── */
  .hero-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }

  /* Directional dark overlay: deepest at left (text) → opens toward the right (photo) */
  .hero-overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(to bottom, oklch(0.06 0.006 55 / 0.70) 0%, transparent 24%),
      linear-gradient(
        108deg,
        oklch(0.05 0.005 52 / 0.95) 0%,
        oklch(0.08 0.008 58 / 0.90) 28%,
        oklch(0.08 0.008 60 / 0.55) 58%,
        oklch(0.08 0.008 60 / 0.18) 100%
      );
  }

  /* Seamless bleed into the next section */
  .hero-fade-bottom {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: clamp(14rem, 22vw, 20rem);
    background: linear-gradient(to top, var(--background) 8%, transparent 100%);
  }

  /* ── Content ──────────────────────────────────────────────── */
  .hero-content {
    position: relative;
    z-index: 1;
    padding: clamp(7rem, 14vw, 11rem) clamp(1.5rem, 5vw, 4rem) clamp(3rem, 5vw, 4rem);
    max-width: 80rem;
    margin: 0 auto;
    width: 100%;
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: center;
    align-self: center;
  }

  @media (min-width: 900px) {
    .hero-content {
      grid-template-columns: 1fr 40%;
    }
  }

  .hero-text {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }

  .hero-portrait-wrap {
    position: relative;
    overflow: hidden;
    height: clamp(280px, 70vw, 400px);
    background: var(--muted);
  }

  @media (min-width: 900px) {
    .hero-portrait-wrap {
      height: clamp(400px, 65vh, 680px);
    }
  }

  .hero-portrait {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }

  /* ── Role label ───────────────────────────────────────────── */
  .hero-label {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .label-line {
    display: block;
    width: 2.5rem;
    height: 1px;
    background: var(--amber);
    flex-shrink: 0;
  }

  .label-text {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--amber);
  }

  /* ── Hero name ────────────────────────────────────────────── */
  .hero-name {
    font-size: clamp(3.5rem, 9vw, 7rem);
    line-height: 0.92;
    letter-spacing: -0.03em;
    color: var(--cream);
    margin: 0;
    overflow-wrap: break-word;
    word-break: break-word;
    /* overflow: hidden applied per-char by GSAP splitter */
  }

  /* ── Title & sub ──────────────────────────────────────────── */
  .hero-title {
    font-size: clamp(1rem, 2vw, 1.25rem);
    font-weight: 400;
    color: var(--fg-muted);
    margin: 0;
    max-width: 44rem;
    line-height: 1.6;
  }

  .accent-word {
    font-style: normal;
    color: var(--amber);
  }

  .hero-sub {
    font-size: clamp(0.875rem, 1.4vw, 1rem);
    color: var(--fg-subtle);
    margin: 0;
    max-width: 32rem;
    line-height: 1.75;
  }

  /* ── CTAs ─────────────────────────────────────────────────── */
  .hero-ctas {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    align-items: center;
  }

  /* ── Social ───────────────────────────────────────────────── */
  .hero-social {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .social-link {
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--fg-subtle);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .social-link:hover { color: var(--amber); }

  .social-sep {
    color: var(--border-strong);
    font-size: 0.875rem;
    user-select: none;
  }

  /* ── Scroll indicator ─────────────────────────────────────── */
  .scroll-indicator {
    position: absolute;
    bottom: clamp(6rem, 10vw, 8rem);
    left: clamp(1.5rem, 5vw, 4rem);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    z-index: 1;
  }

  .scroll-line {
    display: block;
    width: 1px;
    height: 3.5rem;
    background: linear-gradient(to bottom, var(--amber), transparent);
    animation: scroll-pulse 2.5s ease-in-out infinite;
  }

  @keyframes scroll-pulse {
    0%, 100% { transform: scaleY(0.4); transform-origin: top; opacity: 0.5; }
    50%       { transform: scaleY(1);   transform-origin: top; opacity: 1; }
  }

  .scroll-label {
    font-size: 0.625rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--fg-subtle);
    writing-mode: vertical-rl;
    text-orientation: mixed;
  }

  /* ── Tech marquee ─────────────────────────────────────────── */
  .hero-marquee {
    position: relative;
    z-index: 1;
    width: 100%;
    padding: 1.25rem 0;
    border-top: 1px solid var(--border);
  }

  .marquee-viewport {
    overflow: hidden;
    mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 8%,
      black 92%,
      transparent 100%
    );
  }

  .marquee-item {
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--fg-subtle);
    padding: 0 2rem;
    white-space: nowrap;
    position: relative;
  }

  .marquee-item::after {
    content: '·';
    position: absolute;
    right: 0;
    color: var(--border-strong);
    transform: translateX(50%);
  }

  /* ── Reduced motion overrides ─────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .scroll-line        { animation: none; }
    .hero-label,
    #hero-title,
    #hero-sub,
    #hero-ctas,
    #hero-social        { opacity: 1 !important; }
    .hero-name          { opacity: 1 !important; }
  }
</style>

