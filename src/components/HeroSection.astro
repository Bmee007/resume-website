---
// HeroSection.astro — Dark luxury editorial redesign
const techs = [
  "Microsoft Dynamics 365",
  "Manhattan DFIO",
  "Azure OpenAI",
  "IBM AS400",
  "Power Automate",
  "AI Builder",
  "Python / ML",
  "Microsoft Copilot",
  "Claude",
  "Google Gemini",
  "Microsoft Dynamics 365",
  "Manhattan DFIO",
  "Azure OpenAI",
  "IBM AS400",
  "Power Automate",
  "AI Builder",
  "Python / ML",
  "Microsoft Copilot",
  "Claude",
  "Google Gemini",
];
---

<section id="hero" class="hero-root">

  <!-- Gradient orb backgrounds -->
  <div class="hero-bg" aria-hidden="true">
    <div id="hero-orb" class="hero-orb hero-orb--primary"></div>
    <div class="hero-orb hero-orb--secondary"></div>
  </div>

  <!-- Main content -->
  <div class="hero-content">

    <!-- Role badge -->
    <div id="hero-label" class="hero-label">
      <span class="label-line" aria-hidden="true"></span>
      <span class="label-text">ERP &amp; WMS AI Integration Leader</span>
    </div>

    <!-- Massive split-text name — GSAP animates chars -->
    <h1 id="hero-name" class="hero-name display-serif" aria-label="Borina Keo">
      Borina Keo
    </h1>

    <!-- Position descriptor -->
    <p id="hero-title" class="hero-title">
      Bridging <em class="accent-word">Microsoft Dynamics 365</em>,
      Manhattan DFIO, and <em class="accent-word">AI</em> —
      turning legacy ERP &amp; WMS systems into intelligent operations.
    </p>

    <!-- Tagline -->
    <p id="hero-sub" class="hero-sub">
      15+ years of enterprise systems leadership. Quantified outcomes
      across Fortune 500 distribution networks.
    </p>

    <!-- CTAs -->
    <div id="hero-ctas" class="hero-ctas">
      <a href="#contact" class="btn-amber" data-magnetic>
        <span>Let's Connect</span>
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
      <a href="#about" class="btn-ghost" data-magnetic>
        View My Work
      </a>
    </div>

    <!-- Social links -->
    <div id="hero-social" class="hero-social">
      <a
        href="https://www.linkedin.com/in/borinakeo"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="LinkedIn profile"
        class="social-link"
        data-cursor-hover
      >LinkedIn</a>
      <span class="social-sep" aria-hidden="true">/</span>
      <a
        href="https://github.com/Bmee007"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="GitHub profile"
        class="social-link"
        data-cursor-hover
      >GitHub</a>
    </div>

  </div>

  <!-- Scroll indicator -->
  <div class="scroll-indicator" aria-hidden="true">
    <span class="scroll-line"></span>
    <span class="scroll-label">scroll</span>
  </div>

  <!-- Tech marquee -->
  <div class="hero-marquee">
    <div class="marquee-viewport">
      <div class="marquee-track">
        {techs.map((tech) => (
          <span class="marquee-item">{tech}</span>
        ))}
      </div>
    </div>
  </div>

</section>

<style>
  /* ── Root ─────────────────────────────────────────────────── */
  .hero-root {
    position: relative;
    min-height: 100svh;
    display: grid;
    grid-template-rows: 1fr auto auto;
    overflow: hidden;
  }

  /* ── Background orbs ──────────────────────────────────────── */
  .hero-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .hero-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(70px);
    animation: orb-float 10s ease-in-out infinite alternate;
  }

  .hero-orb--primary {
    width: clamp(400px, 65vw, 800px);
    height: clamp(400px, 65vw, 800px);
    top: -20%;
    right: -15%;
    background: radial-gradient(
      circle,
      color-mix(in oklch, var(--amber-glow) 20%, transparent) 0%,
      color-mix(in oklch, var(--amber-glow)  5%, transparent) 45%,
      transparent 70%
    );
  }

  .hero-orb--secondary {
    width: clamp(250px, 35vw, 500px);
    height: clamp(250px, 35vw, 500px);
    bottom: 5%;
    left: -8%;
    background: radial-gradient(
      circle,
      color-mix(in oklch, var(--amber)  8%, transparent) 0%,
      transparent 65%
    );
    animation-delay: -5s;
    animation-duration: 14s;
  }

  @keyframes orb-float {
    0%   { transform: scale(1) translateY(0); opacity: 0.6; }
    100% { transform: scale(1.06) translateY(-24px); opacity: 1; }
  }

  /* ── Content ──────────────────────────────────────────────── */
  .hero-content {
    position: relative;
    z-index: 1;
    padding: clamp(7rem, 14vw, 11rem) clamp(1.5rem, 5vw, 4rem) clamp(3rem, 5vw, 4rem);
    max-width: 80rem;
    margin: 0 auto;
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
    align-self: center;
  }

  /* ── Role label ───────────────────────────────────────────── */
  .hero-label {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .label-line {
    display: block;
    width: 2.5rem;
    height: 1px;
    background: var(--amber);
    flex-shrink: 0;
  }

  .label-text {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--amber);
  }

  /* ── Hero name ────────────────────────────────────────────── */
  .hero-name {
    font-size: clamp(3.5rem, 9vw, 7rem);
    line-height: 0.92;
    letter-spacing: -0.03em;
    color: var(--cream);
    margin: 0;
    overflow-wrap: break-word;
    word-break: break-word;
    /* overflow: hidden applied per-char by GSAP splitter */
  }

  /* ── Title & sub ──────────────────────────────────────────── */
  .hero-title {
    font-size: clamp(1rem, 2vw, 1.25rem);
    font-weight: 400;
    color: var(--fg-muted);
    margin: 0;
    max-width: 44rem;
    line-height: 1.6;
  }

  .accent-word {
    font-style: normal;
    color: var(--amber);
  }

  .hero-sub {
    font-size: clamp(0.875rem, 1.4vw, 1rem);
    color: var(--fg-subtle);
    margin: 0;
    max-width: 32rem;
    line-height: 1.75;
  }

  /* ── CTAs ─────────────────────────────────────────────────── */
  .hero-ctas {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    align-items: center;
  }

  /* ── Social ───────────────────────────────────────────────── */
  .hero-social {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .social-link {
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--fg-subtle);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .social-link:hover { color: var(--amber); }

  .social-sep {
    color: var(--border-strong);
    font-size: 0.875rem;
    user-select: none;
  }

  /* ── Scroll indicator ─────────────────────────────────────── */
  .scroll-indicator {
    position: absolute;
    bottom: clamp(6rem, 10vw, 8rem);
    left: clamp(1.5rem, 5vw, 4rem);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    z-index: 1;
  }

  .scroll-line {
    display: block;
    width: 1px;
    height: 3.5rem;
    background: linear-gradient(to bottom, var(--amber), transparent);
    animation: scroll-pulse 2.5s ease-in-out infinite;
  }

  @keyframes scroll-pulse {
    0%, 100% { transform: scaleY(0.4); transform-origin: top; opacity: 0.5; }
    50%       { transform: scaleY(1);   transform-origin: top; opacity: 1; }
  }

  .scroll-label {
    font-size: 0.625rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--fg-subtle);
    writing-mode: vertical-rl;
    text-orientation: mixed;
  }

  /* ── Tech marquee ─────────────────────────────────────────── */
  .hero-marquee {
    position: relative;
    z-index: 1;
    width: 100%;
    padding: 1.25rem 0;
    border-top: 1px solid var(--border);
  }

  .marquee-viewport {
    overflow: hidden;
    mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 8%,
      black 92%,
      transparent 100%
    );
  }

  .marquee-item {
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--fg-subtle);
    padding: 0 2rem;
    white-space: nowrap;
    position: relative;
  }

  .marquee-item::after {
    content: '·';
    position: absolute;
    right: 0;
    color: var(--border-strong);
    transform: translateX(50%);
  }

  /* ── Reduced motion overrides ─────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .hero-orb           { animation: none; }
    .scroll-line        { animation: none; }
    .hero-label,
    #hero-title,
    #hero-sub,
    #hero-ctas,
    #hero-social        { opacity: 1 !important; }
    .hero-name          { opacity: 1 !important; }
  }
</style>
