---
// AboutSection.astro — Bento grid layout
const stats = [
  { value: 15, suffix: "+", label: "Years of Experience" },
  { value: 2,  suffix: "",  label: "Full ERP Migrations" },
  { value: 5,  suffix: "+", label: "AI Integrations Deployed" },
];
---

<section id="about" class="about-root">

  <span class="section-num" aria-hidden="true">01</span>

  <div class="about-container">

    <!-- Section header -->
    <div class="about-header" data-reveal-heading>
      <span class="eyebrow-accent">About</span>
      <h2 class="display-serif about-heading">
        ERP &amp; WMS<br/>transformation<br/>leader
      </h2>
    </div>

    <!-- Bento grid -->
    <div class="bento-grid">

      <!-- Bio card — spans 2 cols on large screens -->
      <div class="bento-card bento-bio" data-reveal>
        <p class="bio-lead">
          With over a decade of enterprise systems leadership, I bridge the gap between
          complex ERP/WMS platforms and the AI technologies that make them
          intelligent — turning operational data into strategic advantage.
        </p>
        <p class="bio-body">
          I lead enterprise-scale digital transformation programs where legacy
          infrastructure meets modern AI — from migrating IBM AS400 environments
          to Microsoft Dynamics 365 (D365), to implementing Manhattan DFIO for
          warehouse operations serving Fortune 500 distribution networks.
        </p>
        <p class="bio-body">
          My work bridges operational expertise and emerging technology: I design
          and deploy Azure OpenAI integrations, Power Automate workflows, and custom
          ML models that make ERP and WMS systems intelligent. The result is
          measurable: faster fulfillment cycles, reduced inventory variance, and
          supply chains that predict rather than react.
        </p>
        <div class="bio-badge">
          <span class="badge-dot" aria-hidden="true"></span>
          Currently: AI &amp; ERP Integration Lead · Kohl and Frisch
        </div>
      </div>

      <!-- Stat cards -->
      {stats.map((stat) => (
        <div class="bento-card bento-stat" data-reveal>
          <span
            class="stat-num"
            data-count-to={stat.value}
            data-count-suffix={stat.suffix}
          >0{stat.suffix}</span>
          <span class="stat-label">{stat.label}</span>
        </div>
      ))}

      <!-- Visual accent card -->
      <div class="bento-card bento-visual" data-reveal aria-hidden="true">
        <div class="bento-bar"></div>
        <div class="bento-tags">
          <span class="bento-tag">D365</span>
          <span class="bento-tag bento-tag--amber">AI</span>
          <span class="bento-tag">WMS</span>
          <span class="bento-tag">ERP</span>
          <span class="bento-tag bento-tag--amber">Azure</span>
          <span class="bento-tag">ML</span>
          <span class="bento-tag">Python</span>
        </div>
      </div>

    </div>

  </div>
</section>

<style>
  .about-root {
    position: relative;
    padding: clamp(6rem, 10vw, 9rem) clamp(1.5rem, 5vw, 4rem);
    overflow: hidden;
  }

  .about-container {
    max-width: 80rem;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  /* ── Header ───────────────────────────────────────────────── */
  .about-header {
    margin-bottom: clamp(3rem, 5vw, 5rem);
  }

  .about-heading {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    margin: 0;
  }

  /* ── Bento grid ───────────────────────────────────────────── */
  .bento-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  @media (min-width: 640px) {
    .bento-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .bento-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  /* ── Cards ────────────────────────────────────────────────── */
  .bento-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 1rem;
    padding: 2rem;
    transition:
      border-color 0.3s var(--ease-expo-out),
      transform    0.3s var(--ease-expo-out),
      box-shadow   0.3s var(--ease-expo-out);
  }

  .bento-card:hover {
    border-color: var(--border-strong);
    transform: translateY(-3px);
    box-shadow: 0 12px 40px rgba(0,0,0,0.35);
  }

  /* Bio: spans 2 cols on desktop */
  .bento-bio {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  @media (min-width: 1024px) {
    .bento-bio {
      grid-column: 1 / 3;
      grid-row: 1 / 3;
    }
  }

  /* Stats */
  .bento-stat {
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    gap: 0.375rem;
    min-height: 140px;
  }

  /* Visual card: bottom-right on desktop */
  .bento-visual {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    justify-content: space-between;
    min-height: 140px;
  }

  @media (min-width: 1024px) {
    .bento-visual {
      grid-column: 4;
      grid-row: 2;
    }
  }

  /* ── Bio text ─────────────────────────────────────────────── */
  .bio-lead {
    font-size: 1.0625rem;
    color: var(--foreground);
    line-height: 1.75;
    margin: 0;
    font-weight: 400;
  }

  .bio-body {
    font-size: 0.9375rem;
    color: var(--fg-muted);
    line-height: 1.8;
    margin: 0;
  }

  .bio-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8125rem;
    color: var(--fg-muted);
    margin-top: 0.25rem;
  }

  .badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--amber);
    flex-shrink: 0;
    animation: badge-pulse 2.5s ease-in-out infinite;
  }

  @keyframes badge-pulse {
    0%, 100% { opacity: 1; box-shadow: 0 0 0 0 var(--amber-dim); }
    50%       { opacity: 0.7; box-shadow: 0 0 0 4px transparent; }
  }

  /* ── Stat ─────────────────────────────────────────────────── */
  .stat-num {
    font-family: "DM Serif Display", Georgia, serif;
    font-style: italic;
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    color: var(--amber);
    line-height: 1;
    letter-spacing: -0.02em;
    display: block;
  }

  .stat-label {
    font-size: 0.8125rem;
    color: var(--fg-muted);
    line-height: 1.4;
    font-weight: 400;
  }

  /* ── Visual card internals ────────────────────────────────── */
  .bento-bar {
    height: 2px;
    background: linear-gradient(
      to right,
      var(--amber),
      var(--amber-glow),
      transparent
    );
    border-radius: 2px;
  }

  .bento-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .bento-tag {
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--fg-subtle);
    border: 1px solid var(--border);
    border-radius: 0.25rem;
    padding: 0.2rem 0.5rem;
  }

  .bento-tag--amber {
    color: var(--amber);
    border-color: color-mix(in oklch, var(--amber) 30%, transparent);
  }

  /* ── Reveal animation (GSAP uses data-reveal; CSS fallback) ─ */
  [data-reveal] {
    opacity: 0;
    transform: translateY(32px);
    transition:
      opacity   0.7s var(--ease-expo-out),
      transform 0.7s var(--ease-expo-out);
  }

  [data-reveal].is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  [data-reveal-heading] {
    opacity: 0;
    transform: translateX(-24px);
    transition:
      opacity   0.8s var(--ease-expo-out),
      transform 0.8s var(--ease-expo-out);
  }

  [data-reveal-heading].is-visible {
    opacity: 1;
    transform: translateX(0);
  }

  @media (prefers-reduced-motion: reduce) {
    [data-reveal],
    [data-reveal-heading] {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>
