---
const stats = [
  { value: "15+", label: "Years of Experience" },
  { value: "2",   label: "Full ERP Migrations" },
  { value: "5+",  label: "AI Integrations Deployed" },
];
---

<section id="about" class="about-root">
  <div class="about-container section-animate">

    <div class="about-header">
      <p class="section-eyebrow">About</p>
      <h2>ERP &amp; WMS transformation leader<br/>with AI at the core</h2>
    </div>

    <div class="about-grid">
      <div class="about-bio-col">
        <div class="about-bio-card">
          <p class="about-position">
            With over a decade of enterprise systems leadership, I bridge the gap between complex ERP/WMS platforms and the AI technologies that make them intelligent — turning operational data into strategic advantage.
          </p>
          <p class="about-bio">
            I lead enterprise-scale digital transformation programs where legacy infrastructure meets modern AI — from migrating IBM AS400 environments to Microsoft Dynamics 365 (D365), to implementing Manhattan DFIO for warehouse operations serving Fortune 500 distribution networks.
          </p>
          <p class="about-bio">
            My work bridges operational expertise and emerging technology: I design and deploy Azure OpenAI integrations, Power Automate workflows, and custom ML models that make ERP and WMS systems intelligent. The result is measurable: faster fulfillment cycles, reduced inventory variance, and supply chains that predict rather than react.
          </p>
        </div>
      </div>

      <div class="about-stats-col">
        {stats.map(stat => (
          <div class="stat-box">
            <span class="stat-value">{stat.value}</span>
            <span class="stat-label">{stat.label}</span>
          </div>
        ))}
      </div>
    </div>

  </div>
</section>

<style>
  .section-animate {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 600ms var(--ease-expo-out, ease),
                transform 600ms var(--ease-expo-out, ease);
  }
  .section-animate.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
  @media (prefers-reduced-motion: reduce) {
    .section-animate { opacity: 1; transform: none; transition: none; }
  }

  .about-root {
    padding: clamp(4rem, 8vw, 7rem) clamp(1.5rem, 4vw, 3rem);
  }

  .about-container {
    max-width: 72rem;
    margin: 0 auto;
  }

  /* ── Header ───────────────────────────────────────────────── */
  .section-eyebrow {
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--primary);
    margin: 0 0 1rem;
  }

  .about-header {
    margin-bottom: 3.5rem;
  }

  .about-header h2 {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 600;
    color: var(--foreground);
    margin: 0;
    line-height: 1.2;
    letter-spacing: -0.02em;
  }

  /* ── Grid ─────────────────────────────────────────────────── */
  .about-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  @media (min-width: 768px) {
    .about-grid { grid-template-columns: 3fr 2fr; }
  }

  /* ── Bio ──────────────────────────────────────────────────── */
  .about-bio-col {
    display: flex;
    flex-direction: column;
  }

  .about-bio-card {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    padding: 2rem;
    background: var(--secondary);
    border: 1px solid var(--border);
    border-radius: 0.5rem;
  }

  .about-position {
    font-size: 1.0625rem;
    font-weight: 400;
    color: var(--foreground);
    line-height: 1.7;
    margin: 0;
  }

  .about-bio {
    font-size: 0.9375rem;
    font-weight: 400;
    color: var(--fg-muted);
    line-height: 1.75;
    margin: 0;
  }

  /* ── Stats ────────────────────────────────────────────────── */
  .about-stats-col {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .stat-box {
    padding: 1.5rem 1.75rem;
    background: var(--secondary);
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .stat-value {
    font-size: 2.25rem;
    font-weight: 700;
    color: var(--primary);
    line-height: 1.0;
    letter-spacing: -0.02em;
  }

  .stat-label {
    font-size: 0.875rem;
    color: var(--fg-muted);
    font-weight: 400;
  }
</style>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { rootMargin: '-10% 0px -10% 0px', threshold: 0 }
  );
  document.querySelectorAll('#about .section-animate').forEach((el) => observer.observe(el));
</script>
