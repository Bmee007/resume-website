---
const projects = [
  {
    title: "D365 AI Procurement Automation",
    system: "Microsoft Dynamics 365",
    aiTech: "Azure OpenAI",
    outcome: "Reduced purchase order cycle time by 14% and eliminated 12 hours/week of manual review through AI-powered approval routing integrated directly into D365 workflows.",
    githubUrl: "https://github.com/Bmee007",
  },
  {
    title: "Manhattan DFIO Pick Optimization",
    system: "Manhattan DFIO",
    aiTech: "Custom ML / Python",
    outcome: "Deployed AI-driven pick path optimization across 9 distribution centers, increasing warehouse throughput by 20% and reducing labor costs by 21%.",
    githubUrl: "https://github.com/Bmee007",
  },
  {
    title: "Supply Chain Demand Forecasting",
    system: "Power Automate + AI Builder",
    aiTech: "Azure OpenAI",
    outcome: "Built end-to-end demand forecasting pipeline integrating ERP sales data with AI Builder models, improving forecast accuracy by 13% and reducing stockout events by 14%.",
    githubUrl: null,
  },
];
---

<section id="projects" class="projects-root">
  <div class="projects-container section-animate">

    <div class="projects-header">
      <p class="section-eyebrow">Work</p>
      <h2>AI Integrations</h2>
      <p class="projects-tagline">Leading AI-powered transformation across ERP &amp; WMS systems</p>
    </div>

    <div class="projects-grid">
      {projects.map((project) => (
        <div class="project-card">
          <div class="project-card-inner">
            <h3 class="project-title">{project.title}</h3>
            <div class="project-chips">
              <span class="project-chip">{project.system}</span>
              <span class="project-chip">{project.aiTech}</span>
            </div>
            <p class="project-outcome">{project.outcome}</p>
            {project.githubUrl && (
              <a href={project.githubUrl} class="project-github" target="_blank" rel="noopener noreferrer">
                View on GitHub
                <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
                  <path d="M2.5 9.5l7-7M4 2.5h5.5V8"/>
                </svg>
              </a>
            )}
          </div>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  .section-animate {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 600ms var(--ease-expo-out, ease),
                transform 600ms var(--ease-expo-out, ease);
  }
  .section-animate.is-visible { opacity: 1; transform: translateY(0); }
  @media (prefers-reduced-motion: reduce) {
    .section-animate { opacity: 1; transform: none; transition: none; }
  }

  .projects-root {
    padding: clamp(4rem, 8vw, 7rem) clamp(1.5rem, 4vw, 3rem);
    background: var(--secondary);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .projects-container {
    max-width: 72rem;
    margin: 0 auto;
  }

  /* ── Header ───────────────────────────────────────────────── */
  .section-eyebrow {
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--primary);
    margin: 0 0 1rem;
  }

  .projects-header {
    margin-bottom: 3rem;
  }

  .projects-header h2 {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 600;
    color: var(--foreground);
    margin: 0 0 0.5rem;
    letter-spacing: -0.02em;
  }

  .projects-tagline {
    font-size: 1rem;
    color: var(--fg-muted);
    margin: 0;
  }

  /* ── Grid ─────────────────────────────────────────────────── */
  .projects-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  @media (min-width: 768px) {
    .projects-grid { grid-template-columns: repeat(2, 1fr); }
  }

  /* ── Card ─────────────────────────────────────────────────── */
  .project-card {
    background: var(--background);
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    transition: border-color 0.25s var(--ease-expo-out, ease);
  }

  .project-card:hover {
    border-color: color-mix(in oklch, var(--primary) 50%, var(--border));
  }

  .project-card-inner {
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    height: 100%;
  }

  .project-title {
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--foreground);
    margin: 0;
    letter-spacing: -0.01em;
  }

  .project-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .project-chip {
    display: inline-block;
    padding: 0.25rem 0.625rem;
    border-radius: 0.25rem;
    border: 1px solid var(--border);
    font-size: 0.8125rem;
    color: var(--fg-muted);
  }

  .project-outcome {
    font-size: 0.9375rem;
    color: var(--fg-muted);
    line-height: 1.65;
    margin: 0;
    flex: 1;
  }

  .project-github {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--primary);
    text-decoration: none;
    align-self: flex-start;
    transition: opacity 0.2s;
  }

  .project-github:hover { opacity: 0.75; }
</style>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { rootMargin: '-10% 0px -10% 0px', threshold: 0 }
  );
  document.querySelectorAll('#projects .section-animate').forEach((el) => observer.observe(el));
</script>
