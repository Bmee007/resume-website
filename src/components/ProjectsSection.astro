---
// ProjectsSection.astro — Horizontal scroll with GSAP ScrollTrigger pin
const projects = [
  {
    title: "Autonomous Supply Chain Agent",
    system: "Agent Harness · Skills · Workflows",
    aiTech: "Claude / GPT-4o",
    metric: "16",
    metricLabel: "Processes automated end-to-end",
    outcome: "Designed a multi-agent system with custom harness, domain skills, and multi-step planning workflows — autonomously managing demand signals, procurement triggers, and ERP updates across supply chain operations.",
    githubUrl: "https://github.com/Bmee007",
    imageUrl: "/images/supply-chain.jpg",
  },
  {
    title: "LLM Memory Research — Supply Chain Context",
    system: "Episodic · Semantic · Working Memory",
    aiTech: "Python · LLM APIs",
    metric: "13%",
    metricLabel: "Forecast accuracy improvement",
    outcome: "Researching LLM memory architectures (episodic recall, semantic knowledge graphs, working context windows) to ground supply chain AI agents in long-horizon operational history rather than single-session context.",
    githubUrl: null,
    imageUrl: "/images/llm-memory.jpg",
  },
  {
    title: "Agent Security Research & Implementation",
    system: "Prompt Injection · Trust Boundaries",
    aiTech: "Red Teaming · Defense Patterns",
    metric: "100%",
    metricLabel: "Privilege escalation attempts blocked",
    outcome: "Investigating threat models unique to autonomous agents: prompt injection via tool outputs, cross-agent trust escalation, and authorization boundaries. Developing defensive harness patterns that constrain agent actions to least-privilege scopes.",
    githubUrl: "https://github.com/Bmee007",
    imageUrl: "/images/agent-security.jpg",
  },
];
---

<section id="projects" class="projects-root">

  <span class="section-num" aria-hidden="true">04</span>

  <!-- Header -->
  <div class="projects-header-wrap">
    <div class="projects-header" data-reveal-heading>
      <span class="eyebrow-accent">Work</span>
      <h2 class="display-serif projects-heading">AI Agent<br/>Systems</h2>
    </div>
    <p class="projects-hint" aria-hidden="true">
      <span class="hint-arrow">→</span> scroll to explore
    </p>
  </div>

  <!-- Horizontal scroll track (pinned by GSAP on desktop) -->
  <div class="projects-scroll-outer">
    <div id="projects-track" class="projects-track">

      {projects.map((project, i) => (
        <div class="project-card">
          {project.imageUrl && (
            <div
              class="project-card-bg"
              style={`background-image: url('${project.imageUrl}')`}
              aria-hidden="true"
            ></div>
          )}
          <div class="project-card-inner">
            <div class="project-num" aria-hidden="true">0{i + 1}</div>
            <div class="project-top">
              <div class="project-metric">
                <span class="metric-value">{project.metric}</span>
                <span class="metric-label">{project.metricLabel}</span>
              </div>
              <h3 class="project-title">{project.title}</h3>
              <div class="project-chips">
                <span class="project-chip">{project.system}</span>
                <span class="project-chip project-chip--amber">{project.aiTech}</span>
              </div>
            </div>
            <p class="project-outcome">{project.outcome}</p>
            <div class="project-footer">
              {project.githubUrl && (
                <a
                  href={project.githubUrl}
                  class="project-link btn-ghost"
                  target="_blank"
                  rel="noopener noreferrer"
                  data-magnetic
                >
                  View on GitHub
                  <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
                    <path d="M2.5 9.5l7-7M4 2.5h5.5V8"/>
                  </svg>
                </a>
              )}
            </div>
          </div>
        </div>
      ))}

      <!-- End card -->
      <div class="project-card project-card--end" aria-hidden="true">
        <div class="end-card-inner">
          <span class="display-serif end-label">More<br/>to come.</span>
          <a href="#contact" class="btn-amber end-cta">
            <span>Let's work together</span>
          </a>
        </div>
      </div>

    </div>
  </div>

</section>

<style>
  .projects-root {
    position: relative;
    padding-top: clamp(6rem, 10vw, 9rem);
    overflow: hidden;
    background-image: url('/images/Background 5.png');
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }

  .projects-root::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom,
      var(--background) 0%,
      oklch(0.07 0.007 58 / 0.82) 14%,
      oklch(0.07 0.007 58 / 0.82) 86%,
      var(--background) 100%
    );
    pointer-events: none;
    z-index: 0;
  }

  /* ── Header row ───────────────────────────────────────────── */
  .projects-header-wrap {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    padding: 0 clamp(1.5rem, 5vw, 4rem) clamp(2rem, 4vw, 3rem);
    max-width: 80rem;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .projects-heading {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    margin: 0;
  }

  .projects-hint {
    font-size: 0.75rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--fg-subtle);
    display: none;
    align-items: center;
    gap: 0.5rem;
    margin: 0;
    padding-bottom: 0.5rem;
  }

  @media (min-width: 768px) {
    .projects-hint { display: flex; }
  }

  .hint-arrow {
    display: inline-block;
    animation: hint-drift 2s ease-in-out infinite;
  }

  @keyframes hint-drift {
    0%, 100% { transform: translateX(0); }
    50%       { transform: translateX(6px); }
  }

  /* ── Scroll container ─────────────────────────────────────── */
  .projects-scroll-outer {
    overflow: hidden;
    padding: 0 clamp(1.5rem, 5vw, 4rem) clamp(4rem, 7vw, 6rem);
    position: relative;
    z-index: 1;
  }

  /* Track: horizontal on desktop, vertical on mobile */
  .projects-track {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  @media (min-width: 768px) {
    .projects-track {
      flex-direction: row;
      gap: 1.5rem;
      width: max-content;
    }
  }

  /* ── Project cards ────────────────────────────────────────── */
  .project-card {
    position: relative;
    overflow: hidden;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 1rem;
    transition:
      border-color 0.3s var(--ease-expo-out),
      transform    0.3s var(--ease-expo-out),
      box-shadow   0.3s var(--ease-expo-out);
    width: 100%;
  }

  @media (min-width: 768px) {
    .project-card {
      flex-shrink: 0;
      width: clamp(320px, 38vw, 460px);
    }
  }

  .project-card:hover {
    border-color: color-mix(in oklch, var(--amber) 40%, var(--border));
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(0,0,0,0.35),
                0 0 0 1px color-mix(in oklch, var(--amber) 15%, transparent);
  }

  /* ── Background image layer ──────────────────────────────── */
  .project-card-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    opacity: 0.18;
    mask-image: linear-gradient(to bottom, black 0%, transparent 75%);
    -webkit-mask-image: linear-gradient(to bottom, black 0%, transparent 75%);
    transition: opacity 0.4s var(--ease-expo-out);
  }

  .project-card:hover .project-card-bg {
    opacity: 0.30;
  }

  .project-card-inner {
    position: relative;
    z-index: 1;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    height: 100%;
    min-height: 340px;
  }

  /* ── Card number ──────────────────────────────────────────── */
  .project-num {
    font-family: "DM Serif Display", Georgia, serif;
    font-style: italic;
    font-size: 2.5rem;
    color: transparent;
    -webkit-text-stroke: 1px var(--border-strong);
    line-height: 1;
    letter-spacing: -0.02em;
  }

  /* ── Metric display ───────────────────────────────────────── */
  .project-metric {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .metric-value {
    font-family: "DM Serif Display", Georgia, serif;
    font-style: italic;
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    color: var(--amber);
    line-height: 1;
    letter-spacing: -0.03em;
  }

  .metric-label {
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--fg-subtle);
  }

  /* ── Card content ─────────────────────────────────────────── */
  .project-top {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
    flex: 1;
  }

  .project-title {
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--cream);
    margin: 0;
    line-height: 1.35;
  }

  .project-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .project-chip {
    display: inline-block;
    padding: 0.25rem 0.625rem;
    border-radius: 0.25rem;
    border: 1px solid var(--border);
    font-size: 0.8125rem;
    color: var(--fg-muted);
  }

  .project-chip--amber {
    color: var(--amber);
    border-color: color-mix(in oklch, var(--amber) 30%, transparent);
  }

  .project-outcome {
    font-size: 0.9375rem;
    color: var(--fg-muted);
    line-height: 1.7;
    margin: 0;
  }

  .project-footer {
    margin-top: auto;
  }

  .project-link {
    padding: 0.5rem 1rem;
    font-size: 0.875rem;
    border-radius: 0.375rem;
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
  }

  /* ── End card ─────────────────────────────────────────────── */
  .project-card--end {
    border-style: dashed;
    border-color: var(--border);
    background: transparent;
  }

  .project-card--end:hover {
    border-style: dashed;
    border-color: var(--amber);
  }

  .end-card-inner {
    padding: 2.5rem 2rem;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: space-between;
    height: 100%;
    min-height: 340px;
    gap: 2rem;
  }

  .end-label {
    font-size: clamp(2rem, 3.5vw, 2.75rem);
    color: var(--fg-subtle);
    line-height: 1.1;
  }

  .end-cta {
    font-size: 0.875rem;
    padding: 0.625rem 1.25rem;
  }

  /* ── Reveal ───────────────────────────────────────────────── */
  [data-reveal-heading] {
    opacity: 0;
    transform: translateX(-20px);
    transition:
      opacity   0.8s var(--ease-expo-out),
      transform 0.8s var(--ease-expo-out);
  }

  [data-reveal-heading].is-visible {
    opacity: 1;
    transform: translateX(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .hint-arrow { animation: none; }
    [data-reveal-heading] {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>
