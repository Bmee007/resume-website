---
// SkillsSection.astro — Tabbed category layout
const categories = [
  {
    title: "Agent Engineering",
    skills: [
      "Agent Harness Design",
      "Skills & Tool Integration",
      "Multi-Step Workflows",
      "LLM Memory Research",
      "Agent Security & Trust",
      "Prompt Injection Defense",
    ],
  },
  {
    title: "Domain Integration",
    skills: [
      "Supply Chain AI",
      "Healthcare ERP Integration",
      "Retail WMS / TMS",
      "ERP Systems (D365, AS400)",
      "Warehouse Management (DFIO)",
      "Demand Forecasting",
    ],
  },
  {
    title: "AI / Data Science",
    skills: [
      "Python · ML / Statistical Modeling",
      "Azure OpenAI · GPT-4o · Claude",
      "RAG & Vector Retrieval",
      "LLM Evaluation & Monitoring",
      "Power Automate · AI Builder",
      "Data Pipeline Engineering",
    ],
  },
  {
    title: "Leadership",
    skills: [
      "AI Program Leadership",
      "Cross-Functional Team Building",
      "Stakeholder & C-Suite Alignment",
      "Change Management",
      "Enterprise Architecture",
    ],
  },
];
---

<section id="skills" class="skills-root">

  <span class="section-num" aria-hidden="true">02</span>

  <div class="skills-container">

    <div class="skills-header" data-reveal-heading>
      <span class="eyebrow-accent">Expertise</span>
      <h2 class="display-serif skills-heading">
        Skills &amp;<br/>Expertise
      </h2>
      <p class="skills-sub">Specialized across AI Agents · Supply Chain · Data Science · Security</p>
    </div>

    <div class="skills-layout">

      <!-- Category tab list -->
      <div class="skills-categories" role="tablist" aria-label="Skill categories">
        {categories.map((cat, i) => (
          <button
            class:list={["cat-tab", i === 0 && "is-active"]}
            data-category={i}
            role="tab"
            aria-selected={i === 0 ? "true" : "false"}
            aria-controls={`panel-${i}`}
            id={`tab-${i}`}
          >
            <span class="cat-num" aria-hidden="true">0{i + 1}</span>
            <span class="cat-title">{cat.title}</span>
          </button>
        ))}
      </div>

      <!-- Chip panels -->
      <div class="panels-wrap">
        {categories.map((cat, i) => (
          <div
            class:list={["chip-panel", i === 0 && "is-active"]}
            id={`panel-${i}`}
            role="tabpanel"
            aria-labelledby={`tab-${i}`}
            data-panel={i}
          >
            <div class="chip-cloud">
              {cat.skills.map((skill) => (
                <span class="skill-chip" data-reveal>{skill}</span>
              ))}
            </div>
          </div>
        ))}
      </div>

    </div>
  </div>
</section>

<style>
  .skills-root {
    position: relative;
    padding: clamp(6rem, 10vw, 9rem) clamp(1.5rem, 5vw, 4rem);
    background: var(--surface);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    overflow: hidden;
  }

  .skills-container {
    max-width: 80rem;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  /* ── Header ───────────────────────────────────────────────── */
  .skills-header {
    margin-bottom: clamp(3rem, 5vw, 5rem);
  }

  .skills-heading {
    font-size: clamp(2.5rem, 5vw, 4rem);
    margin: 0 0 1rem;
  }

  .skills-sub {
    font-size: 1rem;
    color: var(--fg-muted);
    margin: 0;
    letter-spacing: 0.02em;
  }

  /* ── Layout: sidebar tabs + chip panel ───────────────────── */
  .skills-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  @media (min-width: 768px) {
    .skills-layout {
      grid-template-columns: 200px 1fr;
      gap: 3rem;
      align-items: start;
    }
  }

  /* ── Category tabs ────────────────────────────────────────── */
  .skills-categories {
    display: flex;
    flex-direction: row;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  @media (min-width: 768px) {
    .skills-categories {
      flex-direction: column;
      gap: 0.25rem;
    }
  }

  .cat-tab {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    padding: 0.75rem 1rem;
    border: 1px solid transparent;
    border-radius: 0.5rem;
    background: transparent;
    color: var(--fg-muted);
    text-align: left;
    width: auto;
    transition:
      color      0.2s ease,
      background 0.2s ease,
      border-color 0.2s ease;
  }

  @media (min-width: 768px) {
    .cat-tab { width: 100%; }
  }

  .cat-tab:hover {
    color: var(--cream);
  }

  .cat-tab.is-active {
    background: var(--surface-raised);
    border-color: var(--border);
    color: var(--cream);
  }

  .cat-num {
    font-family: "DM Serif Display", Georgia, serif;
    font-style: italic;
    font-size: 0.875rem;
    color: var(--amber);
    line-height: 1;
    flex-shrink: 0;
    min-width: 1.5rem;
  }

  .cat-title {
    font-size: 0.875rem;
    font-weight: 500;
    letter-spacing: 0.02em;
  }

  /* ── Chip panels ──────────────────────────────────────────── */
  .panels-wrap {
    position: relative;
  }

  .chip-panel {
    display: none;
  }

  .chip-panel.is-active {
    display: block;
  }

  .chip-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    padding: 0.5rem 0;
  }

  .skill-chip {
    display: inline-block;
    padding: 0.5625rem 1.125rem;
    border: 1px solid var(--border);
    border-radius: 2rem;
    font-size: 0.9375rem;
    font-weight: 400;
    color: var(--fg-muted);
    background: var(--background);
    transition:
      border-color 0.25s var(--ease-expo-out),
      color        0.25s var(--ease-expo-out),
      transform    0.25s var(--ease-expo-out),
      box-shadow   0.25s var(--ease-expo-out);
  }

  .skill-chip:hover {
    border-color: var(--amber);
    color: var(--cream);
    transform: translateY(-2px);
    box-shadow: 0 4px 20px color-mix(in oklch, var(--amber) 18%, transparent);
  }

  /* ── Reveal ───────────────────────────────────────────────── */
  [data-reveal] {
    opacity: 0;
    transform: translateY(20px);
    transition:
      opacity   0.6s var(--ease-expo-out),
      transform 0.6s var(--ease-expo-out);
  }

  [data-reveal].is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  [data-reveal-heading] {
    opacity: 0;
    transform: translateX(-20px);
    transition:
      opacity   0.8s var(--ease-expo-out),
      transform 0.8s var(--ease-expo-out);
  }

  [data-reveal-heading].is-visible {
    opacity: 1;
    transform: translateX(0);
  }

  @media (prefers-reduced-motion: reduce) {
    [data-reveal],
    [data-reveal-heading] {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>

<script>
  // Tab switching
  const tabs   = document.querySelectorAll<HTMLButtonElement>('.cat-tab');
  const panels = document.querySelectorAll<HTMLElement>('.chip-panel');

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const idx = tab.dataset.category;

      tabs.forEach((t) => {
        t.classList.toggle('is-active', t === tab);
        t.setAttribute('aria-selected', String(t === tab));
      });

      panels.forEach((p) => {
        p.classList.toggle('is-active', p.dataset.panel === idx);
      });
    });
  });
</script>
