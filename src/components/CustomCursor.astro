---
// CustomCursor.astro — Enhanced lerp cursor with label on hover
---

<div id="custom-cursor" aria-hidden="true">
  <span id="cursor-label" class="cursor-label"></span>
</div>
<div id="custom-cursor-dot" aria-hidden="true"></div>

<style>
  #custom-cursor {
    position: fixed;
    top: 0;
    left: 0;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1.5px solid var(--amber);
    pointer-events: none;
    z-index: 99998;
    opacity: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    transition:
      width      0.35s var(--ease-expo-out),
      height     0.35s var(--ease-expo-out),
      background 0.3s ease,
      border-color 0.3s ease,
      opacity    0.4s ease;
    mix-blend-mode: exclusion;
    will-change: transform;
  }

  #custom-cursor-dot {
    position: fixed;
    top: 0;
    left: 0;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--amber);
    pointer-events: none;
    z-index: 99999;
    opacity: 0;
    transition: opacity 0.4s ease;
    will-change: transform;
  }

  @media (pointer: fine) {
    #custom-cursor     { opacity: 1; }
    #custom-cursor-dot { opacity: 1; }
  }

  #custom-cursor.is-hovering {
    width: 60px;
    height: 60px;
    border-color: transparent;
    background: color-mix(in oklch, var(--amber) 16%, transparent);
  }

  .cursor-label {
    font-family: "Inter", sans-serif;
    font-size: 0.5rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: oklch(0.97 0.010 78);
    opacity: 0;
    transition: opacity 0.2s ease;
    white-space: nowrap;
    position: absolute;
    pointer-events: none;
  }

  #custom-cursor.is-hovering .cursor-label {
    opacity: 1;
  }
</style>

<script>
  if (!window.matchMedia('(pointer: fine)').matches) {
    document.getElementById('custom-cursor')?.remove();
    document.getElementById('custom-cursor-dot')?.remove();
  } else {
    const ring  = document.getElementById('custom-cursor');
    const dot   = document.getElementById('custom-cursor-dot');
    const label = document.getElementById('cursor-label');

    let mouseX = window.innerWidth  / 2;
    let mouseY = window.innerHeight / 2;
    let ringX  = mouseX;
    let ringY  = mouseY;

    document.addEventListener('mousemove', (e) => {
      mouseX = e.clientX;
      mouseY = e.clientY;
      if (dot) dot.style.transform = `translate(${mouseX - 2.5}px, ${mouseY - 2.5}px)`;
    });

    function animateCursor() {
      ringX += (mouseX - ringX) * 0.09;
      ringY += (mouseY - ringY) * 0.09;
      if (ring) ring.style.transform = `translate(${ringX - 22}px, ${ringY - 22}px)`;
      requestAnimationFrame(animateCursor);
    }
    animateCursor();

    // Label text per element type
    function getLabelText(el) {
      const closest = el.closest('a, button, [data-cursor-hover]');
      if (!closest) return '';
      if (closest.tagName === 'A') return 'view';
      if (closest.matches('button[type="submit"]')) return 'send';
      if (closest.tagName === 'BUTTON') return 'click';
      return '';
    }

    document.addEventListener('mouseover', (e) => {
      const target = e.target;
      if (target.closest('a, button, [data-cursor-hover]')) {
        ring?.classList.add('is-hovering');
        if (label) label.textContent = getLabelText(target);
      }
    });

    document.addEventListener('mouseout', (e) => {
      const target = e.target;
      if (target.closest('a, button, [data-cursor-hover]')) {
        ring?.classList.remove('is-hovering');
        if (label) label.textContent = '';
      }
    });

    document.addEventListener('mouseleave', () => {
      if (ring) ring.style.opacity = '0';
      if (dot)  dot.style.opacity  = '0';
    });
    document.addEventListener('mouseenter', () => {
      if (ring) ring.style.opacity = '';
      if (dot)  dot.style.opacity  = '';
    });
  }
</script>
