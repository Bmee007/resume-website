---
// Nav.astro — Dark luxury editorial navigation
---

<header id="site-nav" aria-label="Site navigation">
  <div class="nav-inner">

    <!-- Logo monogram -->
    <a href="#" class="nav-brand" aria-label="Back to top">
      <span class="nav-logo" aria-hidden="true">BK</span>
    </a>

    <!-- Desktop nav links -->
    <nav class="desktop-nav" aria-label="Main navigation">
      <a href="#ask"        class="nav-link">Ask</a>
      <a href="#about"      class="nav-link">About</a>
      <a href="#skills"     class="nav-link">Skills</a>
      <a href="#experience" class="nav-link">Experience</a>
      <a href="#projects"   class="nav-link">Projects</a>
    </nav>

    <!-- CTA + hamburger -->
    <div class="nav-actions">
      <a href="#contact" class="nav-cta btn-ghost">Contact</a>
      <button id="hamburger" class="hamburger-btn" aria-expanded="false" aria-controls="mobile-menu" aria-label="Toggle navigation menu">
        <span class="h-bar"></span>
        <span class="h-bar"></span>
      </button>
    </div>
  </div>
</header>

<!-- Mobile fullscreen overlay -->
<div id="mobile-menu" class="mobile-overlay" role="navigation" aria-label="Mobile navigation" aria-hidden="true">
  <div class="mobile-overlay-inner">
    <nav class="mobile-nav-links">
      <a href="#ask"        class="mobile-link nav-link">Ask</a>
      <a href="#about"      class="mobile-link nav-link">About</a>
      <a href="#skills"     class="mobile-link nav-link">Skills</a>
      <a href="#experience" class="mobile-link nav-link">Experience</a>
      <a href="#projects"   class="mobile-link nav-link">Projects</a>
      <a href="#contact"    class="mobile-link nav-link">Contact</a>
    </nav>
    <div class="mobile-social">
      <a href="https://www.linkedin.com/in/borinakeo" target="_blank" rel="noopener noreferrer" class="mobile-social-link">LinkedIn</a>
      <a href="https://github.com/Bmee007" target="_blank" rel="noopener noreferrer" class="mobile-social-link">GitHub</a>
    </div>
  </div>
</div>

<style>
  /* ── Header bar ───────────────────────────────────────────── */
  #site-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    background: transparent;
    transition:
      background 0.4s ease,
      border-bottom-color 0.4s ease,
      backdrop-filter 0.4s ease;
    border-bottom: 1px solid transparent;
  }

  #site-nav.nav-scrolled {
    background: color-mix(in oklch, var(--background) 88%, transparent);
    border-bottom-color: var(--border);
    backdrop-filter: blur(20px) saturate(1.2);
    -webkit-backdrop-filter: blur(20px) saturate(1.2);
  }

  .nav-inner {
    max-width: 80rem;
    margin: 0 auto;
    padding: 0 clamp(1.5rem, 5vw, 4rem);
    height: 4rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  /* ── Logo ─────────────────────────────────────────────────── */
  .nav-brand {
    display: flex;
    align-items: center;
    text-decoration: none;
    flex-shrink: 0;
  }

  .nav-logo {
    font-family: "DM Serif Display", Georgia, serif;
    font-style: italic;
    font-size: 1.25rem;
    font-weight: 400;
    color: var(--amber);
    letter-spacing: -0.02em;
    line-height: 1;
    border: 1px solid var(--border);
    padding: 0.25rem 0.5rem;
    border-radius: 0.25rem;
    transition: border-color 0.2s ease;
  }

  .nav-brand:hover .nav-logo {
    border-color: var(--amber);
  }

  /* ── Desktop links ────────────────────────────────────────── */
  .desktop-nav {
    display: none;
    align-items: center;
    gap: 2.5rem;
    flex: 1;
    justify-content: center;
  }

  @media (min-width: 768px) {
    .desktop-nav { display: flex; }
    #hamburger   { display: none; }
  }

  .nav-link {
    position: relative;
    color: var(--fg-muted);
    text-decoration: none;
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    transition: color 0.25s var(--ease-expo-out);
    white-space: nowrap;
  }

  /* Center-out underline on hover */
  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -3px;
    left: 50%;
    right: 50%;
    height: 1px;
    background: var(--amber);
    transition:
      left  0.3s var(--ease-expo-out),
      right 0.3s var(--ease-expo-out);
  }

  .nav-link:hover,
  .nav-link.active {
    color: var(--amber);
  }

  .nav-link:hover::after,
  .nav-link.active::after {
    left: 0;
    right: 0;
  }

  /* ── Actions ──────────────────────────────────────────────── */
  .nav-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-shrink: 0;
  }

  .nav-cta {
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.375rem 0.875rem;
    border-radius: 0.25rem;
  }

  /* ── Hamburger ────────────────────────────────────────────── */
  .hamburger-btn {
    background: none;
    border: none;
    padding: 0.5rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 6px;
    transition: opacity 0.2s;
  }

  .hamburger-btn:hover { opacity: 0.7; }

  .h-bar {
    display: block;
    width: 24px;
    height: 1.5px;
    background: var(--foreground);
    transition:
      transform 0.35s var(--ease-expo-out),
      opacity   0.25s ease,
      width     0.3s var(--ease-expo-out);
    transform-origin: center;
  }

  .hamburger-btn[aria-expanded="true"] .h-bar:nth-child(1) {
    transform: translateY(3.75px) rotate(45deg);
  }
  .hamburger-btn[aria-expanded="true"] .h-bar:nth-child(2) {
    transform: translateY(-3.75px) rotate(-45deg);
  }

  /* ── Mobile fullscreen overlay ────────────────────────────── */
  .mobile-overlay {
    position: fixed;
    inset: 0;
    z-index: 49;
    background: var(--background);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.35s var(--ease-expo-out);
  }

  .mobile-overlay.is-open {
    opacity: 1;
    pointer-events: all;
  }

  .mobile-overlay-inner {
    display: flex;
    flex-direction: column;
    gap: 3rem;
    padding: clamp(2rem, 8vw, 4rem);
    width: 100%;
    max-width: 28rem;
  }

  .mobile-nav-links {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .mobile-link {
    font-family: "DM Serif Display", Georgia, serif;
    font-style: italic;
    font-weight: 400;
    font-size: clamp(2rem, 8vw, 2.75rem);
    color: var(--cream);
    text-decoration: none;
    letter-spacing: -0.02em;
    line-height: 1.2;
    display: block;
    /* Override the .nav-link text-transform for mobile */
    text-transform: none;
    letter-spacing: -0.02em;
    font-size: clamp(2rem, 8vw, 2.75rem);
    transition: color 0.2s ease;
    opacity: 0;
    transform: translateY(20px);
  }

  .mobile-link::after { display: none; } /* No underline on mobile links */

  .mobile-link:hover { color: var(--amber); }

  .mobile-overlay.is-open .mobile-link {
    opacity: 1;
    transform: translateY(0);
  }

  /* Stagger via nth-child */
  .mobile-overlay.is-open .mobile-link:nth-child(1) { transition: opacity 0.4s ease 0.05s, transform 0.4s var(--ease-expo-out) 0.05s, color 0.2s ease; }
  .mobile-overlay.is-open .mobile-link:nth-child(2) { transition: opacity 0.4s ease 0.10s, transform 0.4s var(--ease-expo-out) 0.10s, color 0.2s ease; }
  .mobile-overlay.is-open .mobile-link:nth-child(3) { transition: opacity 0.4s ease 0.15s, transform 0.4s var(--ease-expo-out) 0.15s, color 0.2s ease; }
  .mobile-overlay.is-open .mobile-link:nth-child(4) { transition: opacity 0.4s ease 0.20s, transform 0.4s var(--ease-expo-out) 0.20s, color 0.2s ease; }
  .mobile-overlay.is-open .mobile-link:nth-child(5) { transition: opacity 0.4s ease 0.25s, transform 0.4s var(--ease-expo-out) 0.25s, color 0.2s ease; }

  .mobile-social {
    display: flex;
    gap: 1.5rem;
  }

  .mobile-social-link {
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--fg-subtle);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .mobile-social-link:hover { color: var(--amber); }
</style>

<script>
  // ── Scroll spy ───────────────────────────────────────────────
  const navLinks = document.querySelectorAll(".nav-link");
  const sectionObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          navLinks.forEach((link) =>
            link.classList.toggle(
              "active",
              link.getAttribute("href") === `#${entry.target.id}`
            )
          );
        }
      });
    },
    { rootMargin: "-5% 0% -95% 0%", threshold: 0 }
  );
  document.querySelectorAll("section[id]").forEach((s) => sectionObserver.observe(s));

  // ── Nav scroll state (GSAP handles this via initNavScroll, CSS fallback) ──
  const nav = document.getElementById('site-nav');
  window.addEventListener('scroll', () => {
    nav?.classList.toggle('nav-scrolled', window.scrollY > 80);
  }, { passive: true });

  // ── Hamburger / mobile overlay ───────────────────────────────
  const hamburger   = document.getElementById("hamburger");
  const mobileMenu  = document.getElementById("mobile-menu");

  hamburger?.addEventListener("click", () => {
    const isOpen = hamburger.getAttribute("aria-expanded") === "true";
    const nowOpen = !isOpen;
    hamburger.setAttribute("aria-expanded", String(nowOpen));
    mobileMenu?.classList.toggle("is-open", nowOpen);
    mobileMenu?.setAttribute("aria-hidden", String(!nowOpen));
    document.body.style.overflow = nowOpen ? "hidden" : "";
  });

  document.querySelectorAll(".mobile-link").forEach((link) => {
    link.addEventListener("click", () => {
      hamburger?.setAttribute("aria-expanded", "false");
      mobileMenu?.classList.remove("is-open");
      mobileMenu?.setAttribute("aria-hidden", "true");
      document.body.style.overflow = "";
    });
  });
</script>
