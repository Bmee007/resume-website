---
// Nav.astro — Liquid-glass pill navbar, fixed at top
//             Scroll state, active section spy, hamburger menu preserved
---

<header id="site-nav" aria-label="Site navigation">
  <div class="nav-wrapper">
  <!-- Pill wrapper — centered, max 850px -->
  <div class="nav-pill liquid-glass rounded-3xl">

    <!-- Logo -->
    <a href="#" class="nav-brand" aria-label="Back to top">
      <span class="nav-logo-icon" aria-hidden="true">
        <!-- Crosshair icon -->
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round">
          <circle cx="8" cy="8" r="5"/>
          <line x1="8" y1="1" x2="8" y2="3"/>
          <line x1="8" y1="13" x2="8" y2="15"/>
          <line x1="1" y1="8" x2="3" y2="8"/>
          <line x1="13" y1="8" x2="15" y2="8"/>
        </svg>
      </span>
      <span class="nav-brand-text">BK</span>
    </a>

    <!-- Desktop nav links -->
    <nav class="desktop-nav" aria-label="Main navigation">
      <a href="#about" class="nav-link">About</a>
      <a href="#skills" class="nav-link">Skills</a>
      <a href="#experience" class="nav-link">Experience</a>
      <a href="#projects" class="nav-link">Projects</a>
    </nav>

    <!-- CTA + hamburger row -->
    <div class="nav-actions">
      <a href="#contact" class="btn-hero nav-cta rounded-xl">Contact Me</a>

      <!-- Hamburger (mobile only) -->
      <button id="hamburger" aria-expanded="false" aria-controls="mobile-menu" aria-label="Toggle navigation menu">
        <span class="h-bar"></span>
        <span class="h-bar"></span>
        <span class="h-bar"></span>
      </button>
    </div>
  </div>

  <!-- Mobile menu panel -->
  <div id="mobile-menu" class="mobile-menu liquid-glass" role="navigation" aria-label="Mobile navigation">

    <a href="#about"      class="mobile-nav-link nav-link">About</a>
    <a href="#skills"     class="mobile-nav-link nav-link">Skills</a>
    <a href="#experience" class="mobile-nav-link nav-link">Experience</a>
    <a href="#projects"   class="mobile-nav-link nav-link">Projects</a>
    <a href="#contact"    class="mobile-nav-link nav-link">Contact</a>
  </div>
  </div>
</header>

<style>
  /* ── Outer header (positioning shell) ──────────────────── */
  #site-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 1rem 1rem 0;
    pointer-events: none; /* let clicks through the transparent gap */
  }

  /* ── Inner wrapper — constrains pill + dropdown to same max-width ── */
  .nav-wrapper {
    width: 100%;
    max-width: 850px;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
  }

  /* ── Pill ─────────────────────────────────────────────── */
  .nav-pill {
    pointer-events: auto;
    width: 100%;
    padding: 0.625rem 1.25rem;
    border-radius: 1.5rem; /* rounded-3xl */
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
  }

  /* ── Logo ─────────────────────────────────────────────── */
  .nav-brand {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    color: hsl(var(--foreground));
    flex-shrink: 0;
  }

  .nav-logo-icon {
    width: 2rem;
    height: 2rem;
    border-radius: 0.5rem;
    background: linear-gradient(135deg, hsl(var(--primary) / 0.6), hsl(var(--primary)));
    display: flex;
    align-items: center;
    justify-content: center;
    color: hsl(var(--primary-foreground));
  }

  .nav-brand-text {
    font-size: 1.125rem;
    font-weight: 600;
    letter-spacing: 0.04em;
  }

  /* ── Desktop links ────────────────────────────────────── */
  .desktop-nav {
    display: none;
    align-items: center;
    gap: 1.75rem;
    flex: 1;
    justify-content: center;
  }

  @media (min-width: 768px) {
    .desktop-nav { display: flex; }
    #hamburger   { display: none; }
  }

  .nav-link {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    color: hsl(var(--foreground) / 0.9);
    text-decoration: none;
    font-size: 1rem;
    font-weight: 400;
    transition: color 0.2s;
    white-space: nowrap;
  }

  .nav-link:hover,
  .nav-link.active {
    color: hsl(var(--primary));
  }

  /* ── Actions (CTA + hamburger) ────────────────────────── */
  .nav-actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-shrink: 0;
  }

  .nav-cta {
    font-size: 0.875rem;
    padding: 0.375rem 0.875rem;
    text-decoration: none;
  }

  /* ── Hamburger ────────────────────────────────────────── */
  #hamburger {
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
  }

  .h-bar {
    display: block;
    width: 22px;
    height: 2px;
    background: hsl(var(--foreground));
    transition: transform 0.3s ease, opacity 0.3s ease;
  }

  #hamburger[aria-expanded="true"] .h-bar:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  #hamburger[aria-expanded="true"] .h-bar:nth-child(2) {
    opacity: 0;
  }
  #hamburger[aria-expanded="true"] .h-bar:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* ── Mobile menu ──────────────────────────────────────── */
  .mobile-menu {
    pointer-events: auto;
    display: none;
    flex-direction: column;
    width: auto;
    min-width: 180px;
    border-radius: 1rem;
    margin-top: 0.5rem;
    padding: 0.75rem 1.25rem;
    gap: 0.75rem;
  }

  .mobile-menu.open { display: flex; }

  .mobile-nav-link {
    font-size: 1rem;
    padding: 0.25rem 0;
  }
</style>

<script>
  // 1. Scroll spy — no visual state change needed for the pill (always liquid-glass)
  //    but keep active link highlighting
  const navLinks = document.querySelectorAll(".nav-link");
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          navLinks.forEach((link) =>
            link.classList.toggle(
              "active",
              link.getAttribute("href") === `#${entry.target.id}`
            )
          );
        }
      });
    },
    { rootMargin: "-5% 0% -95% 0%", threshold: 0 }
  );
  document.querySelectorAll("section[id]").forEach((s) => observer.observe(s));

  // 2. Hamburger toggle
  const hamburger = document.getElementById("hamburger");
  const mobileMenu = document.getElementById("mobile-menu");
  hamburger?.addEventListener("click", () => {
    const isOpen = hamburger.getAttribute("aria-expanded") === "true";
    hamburger.setAttribute("aria-expanded", String(!isOpen));
    mobileMenu?.classList.toggle("open");
  });

  // 3. Auto-close mobile menu on link tap
  document.querySelectorAll(".mobile-nav-link").forEach((link) => {
    link.addEventListener("click", () => {
      hamburger?.setAttribute("aria-expanded", "false");
      mobileMenu?.classList.remove("open");
    });
  });
</script>
