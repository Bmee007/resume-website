---
import "../styles/global.css";
import Nav from "../components/Nav.astro";
import CustomCursor from "../components/CustomCursor.astro";
import Loader from "../components/Loader.astro";

interface Props {
  title: string;
  description?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  canonicalUrl?: string;
}

const {
  title,
  description = "Borina Keo — AI Systems Engineer & Agent Builder. 15+ years delivering AI agent systems, LLM memory research, and agent security across supply chain, healthcare, and retail.",
  ogTitle = title,
  ogDescription = description,
  ogImage = "/og-image.png",
  canonicalUrl = Astro.url.href,
} = Astro.props;

const siteBase = Astro.site ?? new URL(Astro.request.url).origin;
const ogImageAbsolute = new URL(ogImage, siteBase).href;

const personJsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Borina Keo",
  "jobTitle": "ERP, WMS & TMS AI Systems Engineer",
  "url": siteBase,
  "sameAs": [
    "https://www.linkedin.com/in/borinakeo",
    "https://github.com/Bmee007"
  ],
  "description": "AI systems engineer specializing in agent architecture, LLM memory research, and enterprise ERP, WMS & TMS integration across supply chain and healthcare."
};
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=3" />
    <meta name="theme-color" content="#e08520" />

    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:image" content={ogImageAbsolute} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={ogDescription} />
    <meta name="twitter:image" content={ogImageAbsolute} />

    <!-- JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(personJsonLd)} />
  </head>
  <body>
    <Loader />
    <CustomCursor />
    <Nav />
    <slot />

    <!-- GSAP + Lenis animation system -->
    <script>
      import { initAll } from '../scripts/animations';
      // Run after loader fires body.loaded class
      document.addEventListener('DOMContentLoaded', () => {
        initAll();
      });
    </script>
  </body>
</html>
