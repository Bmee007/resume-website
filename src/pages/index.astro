---
import BaseLayout from "../layouts/BaseLayout.astro";
import HeroSection from "../components/HeroSection.astro";
import AboutSection from "../components/AboutSection.astro";
import SkillsSection from "../components/SkillsSection.astro";
import ExperienceSection from "../components/ExperienceSection.astro";
---
<BaseLayout title="Borina Keo — ERP & WMS AI Integration Leader">

  <HeroSection />

  <AboutSection />

  <SkillsSection />

  <ExperienceSection />

  <section id="projects" class="min-h-screen flex items-center justify-center">
    <p style="color: rgba(248,250,252,0.3); font-family: var(--font-body);">Projects — Phase 3</p>
  </section>

  <section id="contact" class="min-h-screen flex items-center justify-center">
    <p style="color: rgba(248,250,252,0.3); font-family: var(--font-body);">Contact — Phase 4</p>
  </section>

</BaseLayout>
