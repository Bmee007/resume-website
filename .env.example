# ── AI Backend Configuration ──────────────────────────────────────────────────
#
# Option B (recommended for Vercel): Direct OpenAI API
OPENAI_API_KEY=sk-...

# Option A: Self-hosted OpenCode server (run `opencode serve --port 4096` on VPS)
# OPENCODE_API_KEY=your-opencode-key
# OPENCODE_SERVER_URL=http://your-vps-ip:4096

# Optional: override the default model (gpt-4o)
# OPENCODE_MODEL=gpt-4o

# ── LIDA Infographic Service ────────────────────────────────────────────────────
# Deploy lida-service/ to Railway, Render, fly.io, or your own VPS,
# then set this URL. Without it, Panel 2 falls back to DALL-E automatically.
# LIDA_SERVICE_URL=https://your-lida-service.railway.app
